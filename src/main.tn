defmodule Demo do
  def run() do
    argv = System.argv()
    args = runtime_argv(argv)
    dispatch(args, argv)
  end

  defp dispatch(["--help"], _argv) do
    print_usage()
  end

  defp dispatch(["-h"], _argv) do
    print_usage()
  end

  defp dispatch(["emit"], _argv) do
    print_emit_usage()
  end

  defp dispatch(["emit", "--help"], _argv) do
    print_emit_usage()
  end

  defp dispatch(["emit", "-h"], _argv) do
    print_emit_usage()
  end

  defp dispatch(["emit", topic | rest], _argv) do
    LoopHarness.emit(resolve_runtime_project_dir(), topic, join_tokens(rest))
  end

  defp dispatch(["inspect"], _argv) do
    print_inspect_usage()
  end

  defp dispatch(["inspect", "--help"], _argv) do
    print_inspect_usage()
  end

  defp dispatch(["inspect", "-h"], _argv) do
    print_inspect_usage()
  end

  defp dispatch(["inspect" | rest], _argv) do
    handle_inspect(rest)
  end

  defp dispatch(["pi-adapter" | rest], _argv) do
    LoopPiAdapter.run(rest)
  end

  defp dispatch(["memory"], _argv) do
    print_memory_usage()
  end

  defp dispatch(["memory", "--help"], _argv) do
    print_memory_usage()
  end

  defp dispatch(["memory", "add"], _argv) do
    print_memory_add_usage()
  end

  defp dispatch(["memory", "add", "--help"], _argv) do
    print_memory_add_usage()
  end

  defp dispatch(["memory", "list"], _argv) do
    IO.puts(LoopMemory.list_project(resolve_runtime_project_dir()))
  end

  defp dispatch(["memory", "list", project_dir], _argv) do
    IO.puts(LoopMemory.list_project(project_dir))
  end

  defp dispatch(["memory", "add", "learning", "--help"], _argv) do
    IO.puts("Usage: miniloops memory add learning <text...>")
  end

  defp dispatch(["memory", "add", "learning" | rest], _argv) do
    LoopMemory.add_learning(resolve_runtime_project_dir(), join_tokens(rest), "manual")
  end

  defp dispatch(["memory", "add", "preference", "--help"], _argv) do
    IO.puts("Usage: miniloops memory add preference <category> <text...>")
  end

  defp dispatch(["memory", "add", "preference", category | rest], _argv) do
    LoopMemory.add_preference(resolve_runtime_project_dir(), category, join_tokens(rest))
  end

  defp dispatch(["memory", "add", "meta", "--help"], _argv) do
    IO.puts("Usage: miniloops memory add meta <key> <value...>")
  end

  defp dispatch(["memory", "add", "meta", key | rest], _argv) do
    LoopMemory.add_meta(resolve_runtime_project_dir(), key, join_tokens(rest))
  end

  defp dispatch(["memory", "remove", "--help"], _argv) do
    IO.puts("Usage: miniloops memory remove <id> [reason...]")
  end

  defp dispatch(["memory", "remove", id], _argv) do
    LoopMemory.remove(resolve_runtime_project_dir(), id, "manual")
  end

  defp dispatch(["memory", "remove", id | rest], _argv) do
    LoopMemory.remove(resolve_runtime_project_dir(), id, join_tokens(rest))
  end

  defp dispatch(["memory" | _rest], _argv) do
    print_memory_usage()
  end

  defp dispatch(["chain", "list"], _argv) do
    handle_chain_list(resolve_runtime_project_dir())
  end

  defp dispatch(["chain", "list", project_dir], _argv) do
    handle_chain_list(project_dir)
  end

  defp dispatch(["chain", "run", name], argv) do
    handle_chain_run(name, resolve_runtime_project_dir(), argv)
  end

  defp dispatch(["chain", "run", name, project_dir], argv) do
    handle_chain_run(name, project_dir, argv)
  end

  defp dispatch(args, argv) do
    options = parse_run_args(args, resolve_bundle_root(argv))

    case Map.get(options, :usage_error, false) do
      true -> :ok
      _ -> dispatch_run_options(options, argv)
    end
  end

  defp dispatch_run_options(options, argv) do
    case Map.get(options, :chain, nil) do
      nil -> LoopHarness.run(Map.get(options, :project_dir, "."), normalize_prompt(Map.get(options, :prompt, nil)), self_command(argv), options)
      chain_csv -> run_inline_chain(chain_csv, Map.get(options, :project_dir, "."), self_command(argv), options)
    end
  end

  defp handle_chain_list(project_dir) do
    chains = LoopChains.load(project_dir)
    chain_list = LoopChains.list_chains(chains)

    case chain_list do
      [] -> IO.puts("No chains defined. Add [[chain]] sections to chains.toml.")
      _ -> print_chain_list(chain_list)
    end
  end

  defp print_chain_list([]) do
    :ok
  end

  defp print_chain_list([chain | rest]) do
    IO.puts(Map.get(chain, :name, "?") <> ": " <> render_step_names(Map.get(chain, :steps, [])))
    print_chain_list(rest)
  end

  defp render_step_names([]) do
    "(empty)"
  end

  defp render_step_names(steps) do
    join_step_names(steps)
  end

  defp join_step_names([]) do
    ""
  end

  defp join_step_names([step]) do
    Map.get(step, :name, "?")
  end

  defp join_step_names([step | rest]) do
    Map.get(step, :name, "?") <> " -> " <> join_step_names(rest)
  end

  defp handle_chain_run(name, project_dir, argv) do
    chains = LoopChains.load(project_dir)
    chain_spec = LoopChains.resolve_chain(chains, name)

    case chain_spec do
      nil -> IO.puts("chain `" <> name <> "` not found in chains.toml")
      _ -> LoopChains.run(chain_spec, project_dir, self_command(argv), %{})
    end
  end

  defp run_inline_chain(chain_csv, project_dir, self_command, options) do
    chain_spec = LoopChains.parse_inline_chain(chain_csv, project_dir)
    LoopChains.run(chain_spec, project_dir, self_command, options)
  end

  defp handle_inspect(args) do
    spec = parse_inspect_args(args)
    artifact = Map.get(spec, :artifact, "")
    format = Map.get(spec, :format, "")
    project_dir = Map.get(spec, :project_dir, resolve_runtime_project_dir())
    selector = Map.get(spec, :selector, "")

    dispatch_inspect(artifact, selector, project_dir, format)
  end

  defp dispatch_inspect("scratchpad", "", project_dir, "md") do
    LoopHarness.render_scratchpad(project_dir)
  end

  defp dispatch_inspect("memory", "", project_dir, "md") do
    IO.puts(LoopMemory.list_project(project_dir))
  end

  defp dispatch_inspect("memory", "", project_dir, "json") do
    IO.puts(LoopMemory.raw_project(project_dir))
  end

  defp dispatch_inspect("journal", "", project_dir, "json") do
    LoopHarness.render_journal(project_dir)
  end

  defp dispatch_inspect("coordination", "", project_dir, "md") do
    LoopHarness.render_coordination(project_dir)
  end

  defp dispatch_inspect("metrics", "", project_dir, format) do
    LoopHarness.render_metrics(project_dir, format)
  end

  defp dispatch_inspect("metrics", run_id, project_dir, format) do
    LoopHarness.render_metrics_for_run(project_dir, run_id, format)
  end

  defp dispatch_inspect("chain", "", project_dir, "md") do
    IO.puts(LoopChains.render_chain_state(project_dir))
  end

  defp dispatch_inspect("prompt", iteration, project_dir, "md") do
    LoopHarness.render_prompt(project_dir, iteration)
  end

  defp dispatch_inspect("output", iteration, project_dir, "text") do
    LoopHarness.render_output(project_dir, iteration)
  end

  defp dispatch_inspect(artifact, _selector, _project_dir, format) do
    IO.puts("unsupported inspect target `" <> artifact <> "` with format `" <> format <> "`")
  end

  defp parse_inspect_args(args) do
    format_parts = split_inspect_format(args)
    artifact = Map.get(format_parts, :artifact, "")
    format = Map.get(format_parts, :format, "")
    positionals = Map.get(format_parts, :positionals, [])

    parse_inspect_positionals(artifact, format, positionals)
  end

  defp split_inspect_format([artifact | rest]) do
    split_inspect_format_rest(artifact, rest)
  end

  defp split_inspect_format([]) do
    inspect_usage_error("inspect requires an artifact and --format")
  end

  defp split_inspect_format_rest(artifact, rest) do
    count = list_count(rest)

    case count >= 2 do
      true -> split_inspect_format_with_count(artifact, rest, count)
      _ -> inspect_usage_error("inspect requires --format <md|text|json>")
    end
  end

  defp split_inspect_format_with_count(artifact, rest, count) do
    flag = list_at(rest, count - 1)
    format = list_at(rest, count)
    positionals = list_take(rest, count - 2)

    case flag do
      "--format" -> %{artifact: artifact, positionals: positionals, format: format}
      _ -> inspect_usage_error("inspect requires --format <md|text|json>")
    end
  end

  defp parse_inspect_positionals("prompt", format, [selector]) do
    %{artifact: "prompt", selector: selector, project_dir: resolve_runtime_project_dir(), format: format}
  end

  defp parse_inspect_positionals("prompt", format, [selector, project_dir]) do
    %{artifact: "prompt", selector: selector, project_dir: project_dir, format: format}
  end

  defp parse_inspect_positionals("output", format, [selector]) do
    %{artifact: "output", selector: selector, project_dir: resolve_runtime_project_dir(), format: format}
  end

  defp parse_inspect_positionals("output", format, [selector, project_dir]) do
    %{artifact: "output", selector: selector, project_dir: project_dir, format: format}
  end

  defp parse_inspect_positionals("scratchpad", format, []) do
    %{artifact: "scratchpad", selector: "", project_dir: resolve_runtime_project_dir(), format: format}
  end

  defp parse_inspect_positionals("scratchpad", format, [project_dir]) do
    %{artifact: "scratchpad", selector: "", project_dir: project_dir, format: format}
  end

  defp parse_inspect_positionals("memory", format, []) do
    %{artifact: "memory", selector: "", project_dir: resolve_runtime_project_dir(), format: format}
  end

  defp parse_inspect_positionals("memory", format, [project_dir]) do
    %{artifact: "memory", selector: "", project_dir: project_dir, format: format}
  end

  defp parse_inspect_positionals("journal", format, []) do
    %{artifact: "journal", selector: "", project_dir: resolve_runtime_project_dir(), format: format}
  end

  defp parse_inspect_positionals("journal", format, [project_dir]) do
    %{artifact: "journal", selector: "", project_dir: project_dir, format: format}
  end

  defp parse_inspect_positionals("coordination", format, []) do
    %{artifact: "coordination", selector: "", project_dir: resolve_runtime_project_dir(), format: format}
  end

  defp parse_inspect_positionals("coordination", format, [project_dir]) do
    %{artifact: "coordination", selector: "", project_dir: project_dir, format: format}
  end

  defp parse_inspect_positionals("metrics", format, []) do
    %{artifact: "metrics", selector: "", project_dir: resolve_runtime_project_dir(), format: format}
  end

  defp parse_inspect_positionals("metrics", format, [run_id]) do
    %{artifact: "metrics", selector: run_id, project_dir: resolve_runtime_project_dir(), format: format}
  end

  defp parse_inspect_positionals("metrics", format, [run_id, project_dir]) do
    %{artifact: "metrics", selector: run_id, project_dir: project_dir, format: format}
  end

  defp parse_inspect_positionals("chain", format, []) do
    %{artifact: "chain", selector: "", project_dir: resolve_runtime_project_dir(), format: format}
  end

  defp parse_inspect_positionals("chain", format, [project_dir]) do
    %{artifact: "chain", selector: "", project_dir: project_dir, format: format}
  end

  defp parse_inspect_positionals(artifact, _format, _positionals) do
    inspect_usage_error("invalid inspect usage for `" <> artifact <> "`")
  end

  defp inspect_usage_error(message) do
    IO.puts(message)
    %{artifact: "", positionals: [], format: ""}
  end

  defp runtime_argv([command, "run", project_dir | rest]) do
    case is_tonic_command(command) do
      true -> rest
      _ -> drop_program_name([command, "run", project_dir] ++ rest)
    end
  end

  defp runtime_argv([first | rest]) do
    case cli_command(first) do
      true -> [first] ++ rest
      _ -> drop_program_name([first] ++ rest)
    end
  end

  defp runtime_argv([]) do
    []
  end

  defp drop_program_name([_program | rest]) do
    rest
  end

  defp drop_program_name([]) do
    []
  end

  defp parse_run_args(args, bundle_root) do
    finalize_run_args(parse_run_tokens(args, bundle_root, default_run_options()), bundle_root)
  end

  defp parse_run_tokens(["run" | rest], bundle_root, options) do
    parse_run_tokens(rest, bundle_root, options)
  end

  defp parse_run_tokens(["--verbose" | rest], bundle_root, options) do
    parse_run_tokens(rest, bundle_root, Map.put(options, :log_level, "debug"))
  end

  defp parse_run_tokens(["-v" | rest], bundle_root, options) do
    parse_run_tokens(rest, bundle_root, Map.put(options, :log_level, "debug"))
  end

  defp parse_run_tokens(["-b"], _bundle_root, _options) do
    backend_usage_error("missing backend after -b")
  end

  defp parse_run_tokens(["--backend"], _bundle_root, _options) do
    backend_usage_error("missing backend after --backend")
  end

  defp parse_run_tokens(["-b", backend | rest], bundle_root, options) do
    parse_run_tokens(rest, bundle_root, attach_backend_override(options, backend_override_spec(backend)))
  end

  defp parse_run_tokens(["--backend", backend | rest], bundle_root, options) do
    parse_run_tokens(rest, bundle_root, attach_backend_override(options, backend_override_spec(backend)))
  end

  defp parse_run_tokens(["-p"], _bundle_root, _options) do
    preset_usage_error("missing preset after -p")
  end

  defp parse_run_tokens(["--preset"], _bundle_root, _options) do
    preset_usage_error("missing preset after --preset")
  end

  defp parse_run_tokens(["-p", preset | rest], bundle_root, options) do
    next = attach_preset_override(options, preset, bundle_root)
    parse_run_tokens(rest, bundle_root, next)
  end

  defp parse_run_tokens(["--preset", preset | rest], bundle_root, options) do
    next = attach_preset_override(options, preset, bundle_root)
    parse_run_tokens(rest, bundle_root, next)
  end

  defp parse_run_tokens(["--chain"], _bundle_root, _options) do
    IO.puts("missing chain after --chain")
    Map.put(default_run_options(), :usage_error, true)
  end

  defp parse_run_tokens(["--chain", chain_csv | rest], bundle_root, options) do
    parse_run_tokens(rest, bundle_root, Map.put(options, :chain, chain_csv))
  end

  defp parse_run_tokens([], _bundle_root, options) do
    options
  end

  defp parse_run_tokens([token | rest], bundle_root, options) do
    parse_run_tokens(rest, bundle_root, push_positional(options, token))
  end

  defp finalize_run_args(options, bundle_root) do
    positionals = Enum.reverse(Map.get(options, :positionals, []))

    case Map.get(options, :preset_explicit, false) do
      true -> strip_run_parse_fields(Map.put(options, :prompt, join_tokens(positionals)))
      _ -> finalize_run_args_positionals(positionals, options, bundle_root)
    end
  end

  defp finalize_run_args_positionals([], options, _bundle_root) do
    case Map.get(options, :chain, nil) do
      nil -> missing_preset_error()
      _ -> strip_run_parse_fields(options)
    end
  end

  defp finalize_run_args_positionals([first | rest], options, bundle_root) do
    bundled_preset = LoopConfig.resolve_project_dir(first, bundle_root)

    case looks_like_project_dir(first) do
      true -> strip_run_parse_fields(Map.put(Map.put(options, :project_dir, first), :prompt, join_tokens(rest)))
      _ -> finalize_run_args_unresolved(first, rest, bundled_preset, options)
    end
  end

  defp finalize_run_args_unresolved(first, rest, bundled_preset, options) do
    case bundled_preset do
      "" -> unknown_preset_error(first)
      preset_dir -> strip_run_parse_fields(Map.put(Map.put(options, :project_dir, preset_dir), :prompt, join_tokens(rest)))
    end
  end

  defp resolve_runtime_project_dir() do
    case System.env("MINILOOPS_PROJECT_DIR") do
      nil -> "."
      path -> resolve_runtime_project_dir_value(path)
    end
  end

  defp resolve_runtime_project_dir_value("") do
    "."
  end

  defp resolve_runtime_project_dir_value(path) do
    path
  end

  defp normalize_prompt(nil) do
    nil
  end

  defp normalize_prompt("") do
    nil
  end

  defp normalize_prompt(prompt) do
    prompt
  end

  defp default_run_options() do
    %{project_dir: ".", prompt: nil, backend_override: %{}, log_level: nil, chain: nil, preset_explicit: false, positionals: [], usage_error: false}
  end

  defp push_positional(options, token) do
    Map.put(options, :positionals, [token] ++ Map.get(options, :positionals, []))
  end

  defp strip_run_parse_fields(options) do
    options
  end

  defp attach_backend_override(options, override) do
    Map.put(options, :backend_override, override)
  end

  defp attach_preset_override(options, preset, bundle_root) do
    resolved = LoopConfig.resolve_project_dir(preset, bundle_root)

    case resolved do
      "" -> preset_usage_error("preset `" <> preset <> "` not found")
      preset_dir -> Map.put(Map.put(options, :project_dir, preset_dir), :preset_explicit, true)
    end
  end

  defp backend_override_spec("pi") do
    %{kind: "pi", command: "pi", args: [], prompt_mode: "arg"}
  end

  defp backend_override_spec(backend) do
    case claude_backend(backend) do
      true -> %{kind: "command", command: backend, args: ["-p", "--dangerously-skip-permissions"], prompt_mode: "arg"}
      _ -> %{kind: "command", command: backend, args: [], prompt_mode: "arg"}
    end
  end

  defp claude_backend("claude") do
    true
  end

  defp claude_backend(backend) do
    String.ends_with(backend, "/claude")
  end

  defp backend_usage_error(message) do
    IO.puts(message)
    Map.put(default_run_options(), :usage_error, true)
  end

  defp preset_usage_error(message) do
    IO.puts(message)
    Map.put(default_run_options(), :usage_error, true)
  end

  defp missing_preset_error() do
    IO.puts("error: missing required preset argument")
    IO.puts("")
    IO.puts("Usage: miniloops run <preset-name|preset-dir> [prompt...] [flags]")
    IO.puts("")
    IO.puts("Examples:")
    IO.puts("  miniloops run autocode")
    IO.puts("  miniloops run autocode \"Fix the login bug\"")
    IO.puts("  miniloops run examples/autoqa \"QA recent changes\"")
    IO.puts("  miniloops run . \"Run from current directory\"")
    Map.put(default_run_options(), :usage_error, true)
  end

  defp unknown_preset_error(name) do
    IO.puts("error: preset `" <> name <> "` not found")
    IO.puts("")
    IO.puts("The argument `" <> name <> "` is not a valid preset name or directory.")
    IO.puts("A preset must be a directory containing miniloops.toml (or miniloops.conf),")
    IO.puts("or a bundled preset name like `autocode`, `autoqa`, etc.")
    IO.puts("")
    IO.puts("Usage: miniloops run <preset-name|preset-dir> [prompt...] [flags]")
    Map.put(default_run_options(), :usage_error, true)
  end

  defp looks_like_project_dir(path) do
    case System.is_dir(path) do
      true -> LoopConfig.project_has_config(path)
      _ -> false
    end
  end

  defp resolve_bundle_root([command, "run", harness_project | _rest]) do
    case is_tonic_command(command) do
      true -> absolute_path(harness_project)
      _ -> "."
    end
  end

  defp resolve_bundle_root(_argv) do
    "."
  end

  defp self_command([command, "run", harness_project | _rest]) do
    case is_tonic_command(command) do
      true -> "tonic run " <> LoopUtils.shell_quote(absolute_path(harness_project))
      _ -> LoopUtils.shell_quote(command)
    end
  end

  defp self_command([command | _rest]) do
    LoopUtils.shell_quote(command)
  end

  defp self_command([]) do
    "'miniloops'"
  end

  defp absolute_path(path) do
    case String.starts_with(path, "/") do
      true -> path
      _ -> Path.join(System.cwd(), path)
    end
  end

  defp is_tonic_command(command) do
    command == "tonic" or String.ends_with(command, "/tonic")
  end

  defp cli_command("run") do
    true
  end

  defp cli_command("emit") do
    true
  end

  defp cli_command("inspect") do
    true
  end

  defp cli_command("memory") do
    true
  end

  defp cli_command("chain") do
    true
  end

  defp cli_command("pi-adapter") do
    true
  end

  defp cli_command(_value) do
    false
  end

  defp print_usage() do
    IO.puts("miniloops — autonomous LLM loop harness")
    IO.puts("")
    IO.puts("Usage:")
    IO.puts("  miniloops run <preset-name|preset-dir> [prompt...] [flags]")
    IO.puts("  miniloops emit <topic> [summary]")
    IO.puts("  miniloops inspect <artifact> --format <md|text|json>")
    IO.puts("  miniloops memory <list|add|remove> [args]")
    IO.puts("  miniloops chain <list|run> [args]")
    IO.puts("")
    IO.puts("The preset argument is required for `run`. It must be a bundled preset")
    IO.puts("name (e.g. autocode, autoqa) or a path to a directory containing")
    IO.puts("miniloops.toml. Use `.` to run from the current directory.")
    IO.puts("")
    IO.puts("Flags:")
    IO.puts("  -h, --help       Show this help")
    IO.puts("  -v, --verbose    Set log level to debug")
    IO.puts("  -b, --backend    Override backend command")
    IO.puts("  -p, --preset     Resolve a bundled preset name or custom preset dir")
    IO.puts("  --chain          Run an inline chain (comma-separated presets)")
  end

  defp print_chain_usage() do
    IO.puts("Usage:")
    IO.puts("  miniloops chain list [project-dir]")
    IO.puts("  miniloops chain run <name> [project-dir]")
  end

  defp print_emit_usage() do
    IO.puts("Usage:")
    IO.puts("  miniloops emit <topic> [summary]")
  end

  defp print_inspect_usage() do
    IO.puts("Usage:")
    IO.puts("  miniloops inspect <artifact> [selector] [project-dir] --format <md|text|json>")
    IO.puts("")
    IO.puts("Artifacts:")
    IO.puts("  scratchpad, prompt, output, journal, memory, coordination, chain, metrics")
  end

  defp print_memory_usage() do
    IO.puts("Usage:")
    IO.puts("  miniloops memory list [project-dir]")
    IO.puts("  miniloops memory add learning <text...>")
    IO.puts("  miniloops memory add preference <category> <text...>")
    IO.puts("  miniloops memory add meta <key> <value...>")
    IO.puts("  miniloops memory remove <id> [reason...]")
  end

  defp print_memory_add_usage() do
    IO.puts("Usage:")
    IO.puts("  miniloops memory add learning <text...>")
    IO.puts("  miniloops memory add preference <category> <text...>")
    IO.puts("  miniloops memory add meta <key> <value...>")
  end

  defp join_tokens([]) do
    ""
  end

  defp join_tokens([token]) do
    token
  end

  defp join_tokens([token | rest]) do
    token <> " " <> join_tokens(rest)
  end

  defp list_count(list) do
    count_list(list, 0)
  end

  defp count_list([], count) do
    count
  end

  defp count_list([_item | rest], count) do
    count_list(rest, count + 1)
  end

  defp list_at([item | _rest], 1) do
    item
  end

  defp list_at([_item | rest], index) do
    list_at(rest, index - 1)
  end

  defp list_at([], _index) do
    ""
  end

  defp list_take(_list, count) when count <= 0 do
    []
  end

  defp list_take([item | rest], count) do
    [item] ++ list_take(rest, count - 1)
  end

  defp list_take([], _count) do
    []
  end
end
