defmodule LoopHarness do
  def run(project_dir, prompt_override, self_command, run_options) do
    loop = build_loop_context(project_dir, prompt_override, self_command, run_options)
    live_loop = reload_loop(loop)
    live_loop = init_store(live_loop)

    ensure_layout(state_dir(live_loop))
    install_runtime_tools(live_loop)
    append_loop_start(live_loop)
    log(live_loop, :info, "loop start run_id=" <> run_id(live_loop) <> " max_iterations=" <> to_string(max_iterations(live_loop)))

    summary = iterate(live_loop, 1)
    print_summary(summary, live_loop)
  end

  defp init_store(loop) do
    store = %{
      "run_id" => run_id(loop),
      "project_dir" => project_dir(loop),
      "self_command" => self_command(loop),
      "max_iterations" => max_iterations(loop),
      "completion_event" => completion_event(loop),
      "completion_promise" => completion_promise(loop)
    }
    Map.put(loop, :store, store)
  end

  def emit(project_dir, topic, payload) do
    journal_file = resolve_emit_journal_file(project_dir)
    ensure_layout(Path.dirname(journal_file))

    validation = emit_validation_context(project_dir, journal_file)

    case coordination_topic(topic) do
      true -> accept_emit(journal_file, topic, payload, validation)
      _ ->
        case invalid_event(topic, Map.get(validation, :allowed_events, []), Map.get(validation, :parallel_enabled, false), Map.get(validation, :completion_event, "task.complete")) do
          true -> reject_emit(journal_file, topic, validation)
          _ -> accept_emit(journal_file, topic, payload, validation)
        end
    end
  end

  def render_scratchpad(project_dir) do
    render_scratchpad_format(project_dir, "md")
  end

  def render_scratchpad_format(project_dir, format) do
    journal_file = resolve_emit_journal_file(project_dir)
    run_id = ensure_render_run_id(journal_file)
    print_projected_markdown(empty_fallback(render_run_scratchpad_full(read_run_lines(journal_file, run_id))), format)
  end

  def render_prompt(project_dir, iteration) do
    render_prompt_format(project_dir, iteration, "md")
  end

  def render_prompt_format(project_dir, iteration, format) do
    journal_file = resolve_emit_journal_file(project_dir)
    run_id = ensure_render_run_id(journal_file)
    prompt = iteration_field_for_run(journal_file, run_id, iteration, "iteration.start", "prompt")

    case prompt do
      "" -> print_text("missing prompt projection for iteration #{iteration}")
      value -> print_projected_markdown(value, format)
    end
  end

  def render_output(project_dir, iteration) do
    journal_file = resolve_emit_journal_file(project_dir)
    run_id = ensure_render_run_id(journal_file)
    output = iteration_field_for_run(journal_file, run_id, iteration, "iteration.finish", "output")

    case output do
      "" -> print_text("missing output projection for iteration #{iteration}")
      value -> print_text(value)
    end
  end

  def render_journal(project_dir) do
    print_text(read_if_exists(resolve_emit_journal_file(project_dir)))
  end

  def render_coordination(project_dir) do
    render_coordination_format(project_dir, "md")
  end

  def render_coordination_format(project_dir, format) do
    journal_file = resolve_emit_journal_file(project_dir)
    run_id = ensure_render_run_id(journal_file)
    lines = read_run_lines(journal_file, run_id)
    print_projected_markdown(empty_fallback(coordination_from_lines(lines, %{issues: [], slices: [], commits: [], archives: []})), format)
  end

  def render_metrics(project_dir, format) do
    journal_file = resolve_emit_journal_file(project_dir)
    run_id = ensure_render_run_id(journal_file)
    lines = read_run_lines(journal_file, run_id)
    rows = collect_metrics_rows(lines, [])
    print_projected_text(format_metrics(rows, format), format)
  end

  def render_metrics_for_run(project_dir, run_id, format) do
    journal_file = resolve_emit_journal_file(project_dir)
    lines = read_run_lines(journal_file, run_id)
    rows = collect_metrics_rows(lines, [])
    print_projected_text(format_metrics(rows, format), format)
  end

  defp build_loop_context(project_dir, prompt_override, self_command, run_options) do
    resolved_project_dir = absolute_path(project_dir)
    resolved_work_dir = absolute_path(Map.get(run_options, :work_dir, "."))
    config = LoopConfig.load_project(resolved_project_dir)
    topology = LoopTopology.load(resolved_project_dir)
    state_dir = Path.join(resolved_work_dir, LoopConfig.get(config, "core.state_dir", ".miniloop"))
    journal_file = LoopConfig.resolve_journal_file_in(resolved_project_dir, resolved_work_dir)
    memory_file = LoopConfig.resolve_memory_file_in(resolved_project_dir, resolved_work_dir)
    run_id = next_run_id(journal_file, config)
    backend_override = Map.get(run_options, :backend_override, %{})
    cli_log_level = Map.get(run_options, :log_level, nil)
    config_log_level = LoopConfig.get(config, "core.log_level", "info")
    log_level = resolve_log_level(cli_log_level, config_log_level)

    %{paths: %{project_dir: resolved_project_dir, work_dir: resolved_work_dir, state_dir: state_dir, journal_file: journal_file, memory_file: memory_file, tool_path: Path.join(state_dir, "miniloops"), pi_adapter_path: Path.join(state_dir, "pi-adapter")}, runtime: %{run_id: run_id, self_command: self_command, prompt_override: prompt_override, backend_override: backend_override, log_level: log_level}}
    |> reload_loop()
  end

  # Hot-reload: re-reads config/topology each iteration so operators can tune
  # parameters (timeouts, roles, topology edges) mid-run without restarting.
  defp reload_loop(loop) do
    project_dir = project_dir(loop)
    config = LoopConfig.load_project(project_dir)
    topology = LoopTopology.load(project_dir)
    prompt_override = prompt_override(loop)
    backend_override = backend_override(loop)
    backend_command = process_string_override(backend_override, :command, LoopConfig.get(config, "backend.command", "pi"))
    backend_kind = resolve_process_kind(process_string_override(backend_override, :kind, LoopConfig.get(config, "backend.kind", "")), backend_command)
    backend_args = process_list_override(backend_override, :args, config_list_with_fallback(config, "backend.args", []))
    backend_prompt_mode = normalize_prompt_mode(process_string_override(backend_override, :prompt_mode, LoopConfig.get(config, "backend.prompt_mode", "arg")))
    max_iterations = LoopConfig.get_int(config, "event_loop.max_iterations", 3)
    completion_promise = LoopConfig.get(config, "event_loop.completion_promise", "LOOP_COMPLETE")
    completion_event = LoopTopology.completion_event(topology, LoopConfig.get(config, "event_loop.completion_event", "task.complete"))
    required_events = LoopConfig.get_list(config, "event_loop.required_events")
    objective = resolve_prompt(project_dir, config, prompt_override)
    parallel_enabled = truthy_setting(LoopConfig.get(config, "parallel.enabled", "false"))
    parallel_max_branches = LoopConfig.get_int(config, "parallel.max_branches", 3)
    parallel_branch_timeout_ms = LoopConfig.get_int(config, "parallel.branch_timeout_ms", 180000)
    memory_budget_chars = LoopConfig.get_int(config, "memory.prompt_budget_chars", 8000)
    review_every = resolve_review_every(config, topology)
    review_enabled = truthy_setting(LoopConfig.get(config, "review.enabled", "true"))
    backend_timeout_ms = LoopConfig.get_int(config, "backend.timeout_ms", 300000)
    review_timeout_ms = LoopConfig.get_int(config, "review.timeout_ms", 300000)
    review_command = LoopConfig.get(config, "review.command", backend_command)
    review_kind = resolve_process_kind(LoopConfig.get(config, "review.kind", backend_kind), review_command)
    review_args = config_list_with_fallback(config, "review.args", backend_args)
    review_prompt_mode = normalize_prompt_mode(LoopConfig.get(config, "review.prompt_mode", backend_prompt_mode))
    harness_text = read_optional_project_file(project_dir, LoopConfig.get(config, "harness.instructions_file", "harness.md"))
    review_text = resolve_review_prompt(project_dir, config)
    branch_mode = branch_mode(loop)

    live_loop = %{objective: objective, topology: topology, limits: %{max_iterations: max_iterations}, completion: %{promise: completion_promise, event: completion_event, required_events: required_events}, backend: %{kind: backend_kind, command: backend_command, args: backend_args, prompt_mode: backend_prompt_mode, timeout_ms: backend_timeout_ms}, review: %{enabled: review_enabled, every: review_every, kind: review_kind, command: review_command, args: review_args, prompt_mode: review_prompt_mode, prompt: review_text, timeout_ms: review_timeout_ms}, parallel: %{enabled: parallel_enabled, max_branches: parallel_max_branches, branch_timeout_ms: parallel_branch_timeout_ms}, memory: %{budget_chars: memory_budget_chars}, harness: %{instructions: harness_text}, paths: %{project_dir: project_dir, work_dir: work_dir(loop), state_dir: state_dir(loop), journal_file: journal_file(loop), memory_file: memory_file(loop), tool_path: tool_path(loop), pi_adapter_path: pi_adapter_path(loop)}, runtime: %{run_id: run_id(loop), self_command: self_command(loop), prompt_override: prompt_override, backend_override: backend_override, log_level: log_level(loop), branch_mode: branch_mode}, store: store(loop)}

    apply_runtime_mode_overrides(live_loop)
  end

  defp apply_runtime_mode_overrides(loop) do
    case branch_mode(loop) do
      true -> apply_branch_mode_overrides(loop)
      _ -> loop
    end
  end

  defp apply_branch_mode_overrides(loop) do
    loop = Map.put(loop, :limits, %{max_iterations: 1})
    loop = Map.put(loop, :review, Map.put(review_spec(loop), :enabled, false))
    loop = Map.put(loop, :parallel, %{enabled: false, max_branches: parallel_max_branches(loop), branch_timeout_ms: parallel_branch_timeout_ms(loop)})
    Map.put(loop, :backend, Map.put(backend_spec(loop), :timeout_ms, min_timeout(backend_timeout_ms(loop), parallel_branch_timeout_ms(loop))))
  end

  defp iterate(loop, iteration) do
    live_loop = reload_loop(loop)
    install_runtime_tools(live_loop)
    reviewed_loop = maybe_run_hyperagent_review(live_loop, iteration)

    case iteration > max_iterations(reviewed_loop) do
      true -> stop_max_iterations(reviewed_loop, iteration)
      _ -> run_iteration(reviewed_loop, iteration)
    end
  end

  defp maybe_run_hyperagent_review(loop, iteration) do
    case should_run_hyperagent_review(loop, iteration) do
      true -> review_and_reload(loop, iteration)
      _ -> loop
    end
  end

  defp review_and_reload(loop, iteration) do
    run_hyperagent_review(loop, iteration)
    reload_loop(loop)
  end

  defp should_run_hyperagent_review(loop, iteration) do
    review_enabled(loop) and iteration > 1 and divisible_by(iteration - 1, review_every(loop))
  end

  defp run_hyperagent_review(loop, iteration) do
    print_review_banner(loop, iteration)
    run_lines = read_run_lines(journal_file(loop), run_id(loop))
    review_prompt = render_review_prompt_text(loop, iteration, run_lines)

    append_event(journal_file(loop), run_id(loop), to_string(iteration), "review.start", LoopJson.json_field("kind", "hyperagent") <> ", " <> LoopJson.json_field("backend_kind", review_kind(loop)) <> ", " <> LoopJson.json_field("command", review_command(loop)) <> ", " <> LoopJson.json_field("prompt_mode", review_prompt_mode(loop)) <> ", " <> LoopJson.json_field("prompt", review_prompt) <> ", " <> LoopJson.json_field("timeout_ms", to_string(review_timeout_ms(loop))))

    result = System.run(build_review_command(loop, iteration, review_prompt), %{stream: true, timeout_ms: review_timeout_ms(loop)})
    output = Map.get(result, :output, "")
    exit_code = Map.get(result, :exit_code, 1)
    timed_out = Map.get(result, :timed_out, false)

    append_event(journal_file(loop), run_id(loop), to_string(iteration), "review.finish", LoopJson.json_field("kind", "hyperagent") <> ", " <> LoopJson.json_field("exit_code", to_string(exit_code)) <> ", " <> LoopJson.json_field_raw("timed_out", LoopJson.json_bool(timed_out)) <> ", " <> LoopJson.json_field("output", output))
  end

  defp divisible_by(value, divisor) do
    case divisor <= 0 do
      true -> false
      _ -> divisible_by_remainder(value, divisor)
    end
  end

  defp divisible_by_remainder(0, _divisor) do
    true
  end

  defp divisible_by_remainder(value, _divisor) when value < 0 do
    false
  end

  defp divisible_by_remainder(value, divisor) do
    divisible_by_remainder(value - divisor, divisor)
  end

  defp run_iteration(loop, iteration) do
    iter = build_iteration_context(loop, iteration)

    print_iteration_banner(loop, iter)
    append_iteration_start(loop, iter)
    log(loop, :debug, "iteration " <> to_string(iteration) <> " start")
    append_backend_start(loop, iter)
    log(loop, :debug, "backend start command=" <> backend_command(loop))

    start_epoch = epoch_seconds()
    result = System.run(build_backend_command(loop, iter), %{stream: true, timeout_ms: backend_timeout_ms(loop)})
    elapsed_s = epoch_seconds() - start_epoch
    output = Map.get(result, :output, "")
    exit_code = Map.get(result, :exit_code, 1)
    timed_out = Map.get(result, :timed_out, false)

    append_backend_finish(loop, iter, output, exit_code, timed_out)
    append_iteration_finish(loop, iter, output, exit_code, timed_out, elapsed_s)
    log(loop, :debug, "iteration " <> to_string(iteration) <> " finish exit_code=" <> to_string(exit_code))
    print_iteration_footer(iter, elapsed_s)

    case timed_out do
      true -> stop_backend_timeout(loop, iteration, output)
      _ -> case exit_code do
        0 -> finish_iteration(loop, iter, output)
        _ -> stop_backend_failed(loop, iteration, output)
      end
    end
  end

  defp build_iteration_context(loop, iteration) do
    run_lines = read_run_lines(journal_file(loop), run_id(loop))
    scratchpad_text = render_run_scratchpad_prompt(run_lines)
    routing = iteration_routing_context(topology(loop), run_lines)
    recent_event = Map.get(routing, :recent_event, "loop.start")
    allowed_roles = Map.get(routing, :allowed_roles, [])
    allowed_events = Map.get(routing, :allowed_events, [])
    backpressure = latest_invalid_note(run_lines, "")
    memory_text = LoopMemory.render_file(memory_file(loop), memory_budget_chars(loop))
    memory_stats = LoopMemory.stats_file(memory_file(loop), memory_budget_chars(loop))
    invalid_count = invalid_event_count(run_lines, 0)

    %{iteration: iteration, recent_event: recent_event, allowed_roles: allowed_roles, allowed_events: allowed_events, backpressure: backpressure, scratchpad_text: scratchpad_text, memory_text: memory_text, prompt: render_iteration_prompt_text(loop, iteration, recent_event, allowed_roles, allowed_events, backpressure, invalid_count, scratchpad_text, memory_text, memory_stats)}
  end

  defp iteration_routing_context(topology, run_lines) do
    recent_event = routing_event_from_lines(run_lines, "loop.start")

    case reserved_parallel_joined_topic(recent_event) do
      true -> joined_iteration_routing_context(topology, run_lines, recent_event)
      _ -> %{recent_event: recent_event, allowed_roles: LoopTopology.suggested_roles(topology, recent_event), allowed_events: LoopTopology.allowed_events(topology, recent_event)}
    end
  end

  defp joined_iteration_routing_context(topology, run_lines, joined_topic) do
    join_line = latest_wave_join_finish_line(run_lines, joined_topic, "")
    routing_basis = joined_routing_basis(join_line, joined_topic)
    recent_event = joined_recent_event(join_line, joined_topic)
    fallback_roles = LoopTopology.suggested_roles(topology, routing_basis)
    fallback_events = LoopTopology.allowed_events(topology, routing_basis)
    restored_roles = csv_field_list(join_line, "resume_roles")
    restored_events = csv_field_list(join_line, "resume_events")
    allowed_roles = fallback_csv_list(restored_roles, fallback_roles)
    allowed_events = fallback_csv_list(restored_events, fallback_events)

    %{recent_event: recent_event, allowed_roles: allowed_roles, allowed_events: allowed_events}
  end

  defp latest_wave_join_finish_line([], _joined_topic, current) do
    current
  end

  defp latest_wave_join_finish_line([line | rest], joined_topic, current) do
    next =
    case extract_topic(line) do
      "wave.join.finish" -> latest_wave_join_finish_line_value(line, joined_topic, current)
      _ -> current
    end

    latest_wave_join_finish_line(rest, joined_topic, next)
  end

  defp latest_wave_join_finish_line_value(line, joined_topic, current) do
    case extract_field(line, "joined_topic") == joined_topic do
      true -> line
      _ -> current
    end
  end

  defp joined_routing_basis("", joined_topic) do
    default_joined_routing_basis(joined_topic)
  end

  defp joined_routing_basis(join_line, joined_topic) do
    case extract_field(join_line, "routing_basis") do
      "" -> default_joined_routing_basis(joined_topic)
      value -> value
    end
  end

  defp default_joined_routing_basis("explore.parallel.joined") do
    "loop.start"
  end

  defp default_joined_routing_basis(joined_topic) do
    case dispatch_parallel_joined_topic(joined_topic) do
      true -> String.slice(joined_topic, 0, String.length(joined_topic) - String.length(".parallel.joined"))
      _ -> joined_topic
    end
  end

  defp joined_recent_event("", joined_topic) do
    joined_topic
  end

  defp joined_recent_event(join_line, joined_topic) do
    case extract_field(join_line, "resume_recent_event") do
      "" -> joined_topic
      value -> value
    end
  end

  defp csv_field_list("", _field) do
    []
  end

  defp csv_field_list(line, field) do
    case extract_field(line, field) do
      "" -> []
      value -> LoopUtils.split_csv(value)
    end
  end

  defp fallback_csv_list([], fallback) do
    fallback
  end

  defp fallback_csv_list(values, _fallback) do
    values
  end

  defp finish_iteration(loop, iter, output) do
    run_lines = read_run_lines(journal_file(loop), run_id(loop))
    all_topics = topics_from_lines(run_lines)
    turn_lines = lines_for_iteration(run_lines, iteration_string(iter))
    emitted = latest_agent_event_record(turn_lines)
    emitted_topic = Map.get(emitted, :topic, "")
    emitted_payload = Map.get(emitted, :payload, "")

    case invalid_event(emitted_topic, allowed_events(iter), parallel_enabled(loop), completion_event(loop)) do
      true -> reject_invalid_and_continue(loop, iter, emitted_topic)
      _ -> continue_after_valid_turn(loop, iter, output, all_topics, emitted_topic, emitted_payload)
    end
  end

  defp continue_after_valid_turn(loop, iter, output, all_topics, emitted_topic, emitted_payload) do
    case parallel_trigger_topic(emitted_topic) do
      true -> finish_parallel_iteration(loop, iter, emitted_topic, emitted_payload)
      _ -> continue_after_valid_turn_nonparallel(loop, iteration(iter), output, all_topics)
    end
  end

  defp continue_after_valid_turn_nonparallel(loop, iteration, output, all_topics) do
    case completed_via_event(all_topics, completion_event(loop), required_events(loop)) do
      true -> complete_loop(loop, iteration, "completion_event")
      _ -> continue_after_completion_check(loop, iteration, output)
    end
  end

  defp continue_after_completion_check(loop, iteration, output) do
    case completed_via_promise(output, completion_promise(loop)) do
      true -> complete_loop(loop, iteration, "completion_promise")
      _ -> iterate(loop, iteration + 1)
    end
  end

  defp finish_parallel_iteration(loop, iter, emitted_topic, emitted_payload) do
    result = execute_parallel_wave(loop, iter, emitted_topic, emitted_payload)
    reason = Map.get(result, :reason, "parallel_wave_complete")
    wave_id = Map.get(result, :wave_id, "")

    case reason do
      "parallel_wave_complete" -> continue_after_parallel_join(loop, iter, wave_id, emitted_topic)
      _ -> stop_after_parallel_wave(loop, iter, reason, wave_id)
    end
  end

  defp continue_after_parallel_join(loop, iter, wave_id, emitted_topic) do
    joined_topic = parallel_joined_topic(emitted_topic)
    append_wave_join_finish(loop, iter, wave_id, emitted_topic, joined_topic)
    append_harness_event(journal_file(loop), run_id(loop), iteration_string(iter), joined_topic, wave_id)
    iterate(loop, iteration(iter) + 1)
  end

  defp stop_after_parallel_wave(loop, iter, reason, wave_id) do
    fields = LoopJson.json_field("reason", reason) <> ", " <> LoopJson.json_field("iteration", iteration_string(iter)) <> parallel_stop_wave_fields(wave_id)

    append_event(journal_file(loop), run_id(loop), iteration_string(iter), "loop.stop", fields)
    %{iterations: iteration(iter), stop_reason: reason}
  end

  defp parallel_stop_wave_fields("") do
    ""
  end

  defp parallel_stop_wave_fields(wave_id) do
    ", " <> LoopJson.json_field("wave_id", wave_id)
  end

  defp reject_invalid_and_continue(loop, iter, emitted_topic) do
    append_invalid_event(journal_file(loop), run_id(loop), iteration_string(iter), recent_event(iter), emitted_topic, allowed_roles(iter), allowed_events(iter))

    iterate(loop, iteration(iter) + 1)
  end

  defp invalid_event("", _allowed_events, _parallel_enabled, _completion_event) do
    false
  end

  defp invalid_event(emitted_topic, allowed_events, parallel_enabled, completion_event) do
    case reserved_parallel_joined_topic(emitted_topic) do
      true -> true
      _ -> invalid_event_after_join_check(emitted_topic, allowed_events, parallel_enabled, completion_event)
    end
  end

  defp invalid_event_after_join_check(emitted_topic, allowed_events, false, _completion_event) do
    case parallel_topic(emitted_topic) do
      true -> true
      _ -> invalid_event_after_parallel_check(emitted_topic, allowed_events)
    end
  end

  defp invalid_event_after_join_check(emitted_topic, allowed_events, true, completion_event) do
    case parallel_topic(emitted_topic) do
      true -> invalid_parallel_topic(emitted_topic, allowed_events, completion_event)
      _ -> invalid_event_after_parallel_check(emitted_topic, allowed_events)
    end
  end

  defp invalid_parallel_topic(emitted_topic, allowed_events, completion_event) do
    case valid_parallel_trigger_event(emitted_topic, allowed_events, completion_event) do
      true -> false
      _ -> true
    end
  end

  defp invalid_event_after_parallel_check(_emitted_topic, []) do
    false
  end

  defp invalid_event_after_parallel_check(emitted_topic, allowed_events) do
    not LoopTopology.event_matches_any(emitted_topic, allowed_events)
  end

  defp valid_parallel_trigger_event("explore.parallel", _allowed_events, _completion_event) do
    true
  end

  defp valid_parallel_trigger_event(emitted_topic, allowed_events, completion_event) do
    base_event = parallel_dispatch_base(emitted_topic)

    case base_event do
      "" -> false
      _ -> valid_parallel_dispatch_base(base_event, allowed_events, completion_event)
    end
  end

  defp valid_parallel_dispatch_base(base_event, allowed_events, completion_event) do
    case base_event == completion_event do
      true -> false
      _ -> valid_parallel_dispatch_base_noncompletion(base_event, allowed_events)
    end
  end

  defp valid_parallel_dispatch_base_noncompletion(base_event, allowed_events) do
    case coordination_topic(base_event) or core_system_topic(base_event) or parallel_topic(base_event) do
      true -> false
      _ -> valid_parallel_dispatch_allowed(base_event, allowed_events)
    end
  end

  defp valid_parallel_dispatch_allowed(_base_event, []) do
    false
  end

  defp valid_parallel_dispatch_allowed(base_event, allowed_events) do
    LoopTopology.event_matches_any(base_event, allowed_events)
  end

  defp parallel_dispatch_base(topic) do
    case dispatch_parallel_topic(topic) do
      true -> String.slice(topic, 0, String.length(topic) - String.length(".parallel"))
      _ -> ""
    end
  end

  defp dispatch_parallel_join_base("explore.parallel.joined") do
    "loop.start"
  end

  defp dispatch_parallel_join_base(topic) do
    case dispatch_parallel_joined_topic(topic) do
      true -> String.slice(topic, 0, String.length(topic) - String.length(".parallel.joined"))
      _ -> topic
    end
  end

  defp parallel_joined_topic(topic) do
    topic <> ".joined"
  end

  defp dispatch_parallel_topic("explore.parallel") do
    false
  end

  defp dispatch_parallel_topic(topic) do
    String.ends_with(topic, ".parallel")
  end

  defp parallel_trigger_topic("explore.parallel") do
    true
  end

  defp parallel_trigger_topic(topic) do
    dispatch_parallel_topic(topic)
  end

  defp dispatch_parallel_joined_topic("explore.parallel.joined") do
    false
  end

  defp dispatch_parallel_joined_topic(topic) do
    String.ends_with(topic, ".parallel.joined")
  end

  defp reserved_parallel_joined_topic(topic) do
    String.ends_with(topic, ".parallel.joined")
  end

  defp parallel_topic(topic) do
    parallel_trigger_topic(topic) or reserved_parallel_joined_topic(topic)
  end

  defp execute_parallel_wave(loop, iter, emitted_topic, emitted_payload) do
    marker_path = active_wave_marker_path(loop)

    case active_wave_present(marker_path) do
      true -> reject_active_parallel_wave(loop, iter, emitted_topic, marker_path)
      _ -> execute_parallel_wave_without_active(loop, iter, emitted_topic, emitted_payload, marker_path)
    end
  end

  defp execute_parallel_wave_without_active(loop, iter, emitted_topic, emitted_payload, marker_path) do
    parse_result = parse_parallel_objectives(emitted_payload, parallel_max_branches(loop))

    case Map.get(parse_result, :ok, false) do
      true -> execute_parallel_wave_with_objectives(loop, iter, emitted_topic, Map.get(parse_result, :objectives, []), marker_path)
      _ -> reject_parallel_payload(loop, iter, emitted_topic, Map.get(parse_result, :reason, "invalid_payload"))
    end
  end

  defp reject_active_parallel_wave(loop, iter, emitted_topic, marker_path) do
    active_wave_id = read_if_exists(marker_path)
    append_wave_invalid(loop, iter, emitted_topic, "active_wave_exists", active_wave_id)
    %{reason: "parallel_wave_invalid", wave_id: active_wave_id}
  end

  defp reject_parallel_payload(loop, iter, emitted_topic, reason) do
    append_wave_invalid(loop, iter, emitted_topic, reason, "")
    %{reason: "parallel_wave_invalid", wave_id: ""}
  end

  defp execute_parallel_wave_with_objectives(loop, iter, emitted_topic, objectives, marker_path) do
    wave_id = next_wave_id()
    wave_dir = wave_dir_path(loop, wave_id)
    branches_dir = Path.join(wave_dir, "branches")
    opening_roles = allowed_roles(iter)
    opening_events = allowed_events(iter)

    System.ensure_dir(branches_dir)
    write_active_wave_marker(marker_path, wave_id)
    write_wave_spec(wave_dir, wave_id, emitted_topic, iter, objectives)
    append_wave_start(loop, iter, wave_id, emitted_topic, objectives)

    branch_results = run_parallel_branches(loop, iter, wave_id, wave_dir, emitted_topic, objectives, 1, [])
    write_wave_join(wave_dir, wave_id, emitted_topic, objectives, branch_results, recent_event(iter), opening_roles, opening_events)
    append_wave_join_start(loop, iter, wave_id, emitted_topic, objectives, branch_results)
    clear_active_wave_marker(marker_path)

    finalize_parallel_wave(loop, iter, wave_id, branch_results)
  end

  defp finalize_parallel_wave(loop, iter, wave_id, branch_results) do
    timed_out = collect_branch_ids_with_status(branch_results, "backend_timeout", [])
    failed = collect_failed_branch_ids(branch_results, [])

    case timed_out do
      [] -> finalize_parallel_wave_without_timeout(loop, iter, wave_id, failed)
      _ -> finalize_parallel_wave_timeout(loop, iter, wave_id, timed_out)
    end
  end

  defp finalize_parallel_wave_without_timeout(loop, iter, wave_id, []) do
    %{reason: "parallel_wave_complete", wave_id: wave_id}
  end

  defp finalize_parallel_wave_without_timeout(loop, iter, wave_id, failed) do
    append_event(journal_file(loop), run_id(loop), iteration_string(iter), "wave.failed", LoopJson.json_field("wave_id", wave_id) <> ", " <> LoopJson.json_field("failed_branches", LoopUtils.join_csv(failed)))
    %{reason: "parallel_wave_failed", wave_id: wave_id}
  end

  defp finalize_parallel_wave_timeout(loop, iter, wave_id, timed_out) do
    append_event(journal_file(loop), run_id(loop), iteration_string(iter), "wave.timeout", LoopJson.json_field("wave_id", wave_id) <> ", " <> LoopJson.json_field("timed_out_branches", LoopUtils.join_csv(timed_out)))
    %{reason: "parallel_wave_timeout", wave_id: wave_id}
  end

  defp collect_branch_ids_with_status([], _status, acc) do
    Enum.reverse(acc)
  end

  defp collect_branch_ids_with_status([branch | rest], status, acc) do
    branch_status = Map.get(branch, :stop_reason, "")

    case branch_status == status do
      true -> collect_branch_ids_with_status(rest, status, [Map.get(branch, :branch_id, "")] ++ acc)
      _ -> collect_branch_ids_with_status(rest, status, acc)
    end
  end

  defp collect_failed_branch_ids([], acc) do
    Enum.reverse(acc)
  end

  defp collect_failed_branch_ids([branch | rest], acc) do
    branch_status = Map.get(branch, :stop_reason, "")

    case branch_success_status(branch_status) do
      true -> collect_failed_branch_ids(rest, acc)
      _ -> collect_failed_branch_ids(rest, [Map.get(branch, :branch_id, "")] ++ acc)
    end
  end

  defp branch_success_status("max_iterations") do
    true
  end

  defp branch_success_status("completion_event") do
    true
  end

  defp branch_success_status("completion_promise") do
    true
  end

  defp branch_success_status(_status) do
    false
  end

  defp run_parallel_branches(_loop, _iter, _wave_id, _wave_dir, _emitted_topic, [], _index, acc) do
    Enum.reverse(acc)
  end

  defp run_parallel_branches(loop, iter, wave_id, wave_dir, emitted_topic, [objective | rest], index, acc) do
    branch_id = "branch-" <> to_string(index)
    branch_dir = Path.join(Path.join(wave_dir, "branches"), branch_id)
    routing_event = branch_routing_event(iter, emitted_topic)
    branch_roles = LoopTopology.suggested_roles(topology(loop), routing_event)
    branch_events = LoopTopology.allowed_events(topology(loop), routing_event)

    System.ensure_dir(branch_dir)
    System.write_text(Path.join(branch_dir, "objective.md"), render_branch_objective(objective, emitted_topic, routing_event, branch_roles, branch_events))
    append_wave_branch_start(loop, iter, wave_id, branch_id, objective, routing_event, branch_roles, branch_events)

    result = run_parallel_branch(loop, branch_dir, objective, emitted_topic, routing_event, branch_roles, branch_events)
    branch_result = Map.put(result, :branch_id, branch_id)

    append_wave_branch_finish(loop, iter, wave_id, branch_id, branch_result)

    run_parallel_branches(loop, iter, wave_id, wave_dir, emitted_topic, rest, index + 1, [branch_result] ++ acc)
  end

  defp run_parallel_branch(loop, branch_dir, objective, emitted_topic, routing_event, branch_roles, branch_events) do
    branch_prompt = render_branch_prompt(loop, objective, emitted_topic, routing_event, branch_roles, branch_events)
    branch_loop = build_branch_loop(loop, branch_dir, branch_prompt)
    seeded_branch_loop = seed_branch_context(branch_loop, routing_event)
    started_ms = epoch_milliseconds()
    summary = iterate(seeded_branch_loop, 1)
    elapsed_ms = epoch_milliseconds() - started_ms
    output = iteration_field_for_run(journal_file(seeded_branch_loop), run_id(seeded_branch_loop), "1", "iteration.finish", "output")
    stop_reason = branch_stop_reason(Map.get(summary, :stop_reason, "unknown"), elapsed_ms, parallel_branch_timeout_ms(loop))
    result = %{objective: objective, stop_reason: stop_reason, output: output, routing_event: routing_event, allowed_roles: branch_roles, allowed_events: branch_events, branch_dir: branch_dir, elapsed_ms: elapsed_ms}

    System.write_text(Path.join(branch_dir, "result.md"), render_branch_result(result))
    result
  end

  defp branch_stop_reason("backend_timeout", _elapsed_ms, _timeout_ms) do
    "backend_timeout"
  end

  defp branch_stop_reason(stop_reason, elapsed_ms, timeout_ms) do
    case elapsed_ms > timeout_ms do
      true -> "backend_timeout"
      _ -> stop_reason
    end
  end

  defp build_branch_loop(loop, branch_dir, branch_prompt) do
    branch_loop = build_loop_context(project_dir(loop), branch_prompt, self_command(loop), %{work_dir: branch_dir, backend_override: backend_override(loop), log_level: log_level(loop)})
    branch_loop = reload_loop(branch_loop)
    branch_loop = init_store(branch_loop)
    branch_loop = Map.put(branch_loop, :runtime, Map.put(Map.get(branch_loop, :runtime, %{}), :branch_mode, true))
    branch_loop = apply_runtime_mode_overrides(branch_loop)

    ensure_layout(state_dir(branch_loop))
    install_runtime_tools(branch_loop)
    append_loop_start(branch_loop)
    branch_loop
  end

  defp seed_branch_context(branch_loop, "loop.start") do
    branch_loop
  end

  defp seed_branch_context(branch_loop, routing_event) do
    append_agent_event(journal_file(branch_loop), run_id(branch_loop), "", routing_event, "branch routing seed")
    branch_loop
  end

  defp branch_routing_event(iter, "explore.parallel") do
    recent_event(iter)
  end

  defp branch_routing_event(_iter, emitted_topic) do
    parallel_dispatch_base(emitted_topic)
  end

  defp min_timeout(left, right) do
    case left <= right do
      true -> left
      _ -> right
    end
  end

  defp parse_parallel_objectives(payload, max_branches) do
    lines = collect_lines(String.split(payload, LoopUtils.line_sep()), [])
    parsed = collect_parallel_objectives(lines, [], false)
    objectives = Map.get(parsed, :objectives, [])

    case Map.get(parsed, :invalid, false) do
      true -> %{ok: false, reason: "invalid_branch_list"}
      _ -> validate_parallel_objective_count(objectives, max_branches)
    end
  end

  defp collect_parallel_objectives([], objectives, invalid) do
    %{objectives: Enum.reverse(objectives), invalid: invalid}
  end

  defp collect_parallel_objectives([line | rest], objectives, invalid) do
    objective = parse_parallel_objective_line(line)

    case objective do
      "" -> collect_parallel_objectives(rest, objectives, true)
      _ -> collect_parallel_objectives(rest, [objective] ++ objectives, invalid)
    end
  end

  defp parse_parallel_objective_line(line) do
    bullet = bullet_parallel_objective(line)

    case bullet do
      "" -> numbered_parallel_objective(line)
      _ -> bullet
    end
  end

  defp bullet_parallel_objective(line) do
    trimmed = String.trim(line)

    case String.starts_with(trimmed, "- ") or String.starts_with(trimmed, "* ") do
      true -> String.trim(String.slice(trimmed, 2, String.length(trimmed) - 2))
      _ -> ""
    end
  end

  defp numbered_parallel_objective(line) do
    trimmed = String.trim(line)
    parts = String.split(trimmed, ". ")

    case parts do
      [prefix | rest] -> finalize_numbered_parallel_objective(prefix, rest)
      _ -> ""
    end
  end

  defp finalize_numbered_parallel_objective(prefix, []) do
    ""
  end

  defp finalize_numbered_parallel_objective(prefix, rest) do
    case digits_only(prefix) do
      true -> String.trim(rejoin_with_separator(rest, ". "))
      _ -> ""
    end
  end

  defp digits_only(text) do
    case Integer.parse(text) do
      {_value, ""} -> true
      _ -> false
    end
  end

  defp validate_parallel_objective_count([], _max_branches) do
    %{ok: false, reason: "empty_branch_list"}
  end

  defp validate_parallel_objective_count(objectives, max_branches) do
    count = list_length(objectives, 0)

    case count > max_branches do
      true -> %{ok: false, reason: "too_many_branches"}
      _ -> %{ok: true, objectives: objectives}
    end
  end

  defp rejoin_with_separator([], _separator) do
    ""
  end

  defp rejoin_with_separator([part], _separator) do
    part
  end

  defp rejoin_with_separator([part | rest], separator) do
    part <> separator <> rejoin_with_separator(rest, separator)
  end

  defp next_wave_id() do
    LoopUtils.generate_compact_id("wave")
  end

  defp wave_dir_path(loop, wave_id) do
    Path.join(Path.join(state_dir(loop), "waves"), wave_id)
  end

  defp active_wave_marker_path(loop) do
    Path.join(Path.join(state_dir(loop), "waves"), "active")
  end

  defp active_wave_present(marker_path) do
    System.path_exists(marker_path)
  end

  defp write_active_wave_marker(marker_path, wave_id) do
    System.ensure_dir(Path.dirname(marker_path))
    System.write_text(marker_path, wave_id)
  end

  defp clear_active_wave_marker(marker_path) do
    System.run("rm -f " <> LoopUtils.shell_quote(marker_path))
  end

  defp append_wave_invalid(loop, iter, emitted_topic, reason, active_wave_id) do
    append_event(journal_file(loop), run_id(loop), iteration_string(iter), "wave.invalid", LoopJson.json_field("trigger_topic", emitted_topic) <> ", " <> LoopJson.json_field("reason", reason) <> ", " <> LoopJson.json_field("active_wave_id", active_wave_id) <> ", " <> LoopJson.json_field("opening_recent_event", recent_event(iter)))
  end

  defp append_wave_start(loop, iter, wave_id, emitted_topic, objectives) do
    append_event(journal_file(loop), run_id(loop), iteration_string(iter), "wave.start", LoopJson.json_field("wave_id", wave_id) <> ", " <> LoopJson.json_field("trigger_topic", emitted_topic) <> ", " <> LoopJson.json_field("branch_count", to_string(list_length(objectives, 0))) <> ", " <> LoopJson.json_field("opening_recent_event", recent_event(iter)) <> ", " <> LoopJson.json_field("opening_roles", LoopUtils.join_csv(allowed_roles(iter))) <> ", " <> LoopJson.json_field("opening_events", LoopUtils.join_csv(allowed_events(iter))) <> ", " <> LoopJson.json_field("objectives", LoopUtils.join_csv(objectives)))
  end

  defp append_wave_branch_start(loop, iter, wave_id, branch_id, objective, routing_event, branch_roles, branch_events) do
    append_event(journal_file(loop), run_id(loop), iteration_string(iter), "wave.branch.start", LoopJson.json_field("wave_id", wave_id) <> ", " <> LoopJson.json_field("branch_id", branch_id) <> ", " <> LoopJson.json_field("objective", objective) <> ", " <> LoopJson.json_field("routing_event", routing_event) <> ", " <> LoopJson.json_field("branch_roles", LoopUtils.join_csv(branch_roles)) <> ", " <> LoopJson.json_field("branch_events", LoopUtils.join_csv(branch_events)))
  end

  defp append_wave_branch_finish(loop, iter, wave_id, branch_id, branch_result) do
    append_event(journal_file(loop), run_id(loop), iteration_string(iter), "wave.branch.finish", LoopJson.json_field("wave_id", wave_id) <> ", " <> LoopJson.json_field("branch_id", branch_id) <> ", " <> LoopJson.json_field("stop_reason", Map.get(branch_result, :stop_reason, "unknown")) <> ", " <> LoopJson.json_field("output", Map.get(branch_result, :output, "")))
  end

  defp append_wave_join_start(loop, iter, wave_id, emitted_topic, objectives, branch_results) do
    append_event(journal_file(loop), run_id(loop), iteration_string(iter), "wave.join.start", LoopJson.json_field("wave_id", wave_id) <> ", " <> LoopJson.json_field("trigger_topic", emitted_topic) <> ", " <> LoopJson.json_field("branch_count", to_string(list_length(objectives, 0))) <> ", " <> LoopJson.json_field("branch_outcomes", render_branch_outcomes_csv(branch_results)))
  end

  defp append_wave_join_finish(loop, iter, wave_id, emitted_topic, joined_topic) do
    routing_basis = joined_resume_routing_basis(loop, iter, emitted_topic)
    resume_recent_event = joined_resume_recent_event(iter, emitted_topic, joined_topic)
    resume_roles = joined_resume_roles(loop, iter, emitted_topic, routing_basis)
    resume_events = joined_resume_events(loop, iter, emitted_topic, routing_basis)

    append_event(journal_file(loop), run_id(loop), iteration_string(iter), "wave.join.finish", LoopJson.json_field("wave_id", wave_id) <> ", " <> LoopJson.json_field("trigger_topic", emitted_topic) <> ", " <> LoopJson.json_field("joined_topic", joined_topic) <> ", " <> LoopJson.json_field("routing_basis", routing_basis) <> ", " <> LoopJson.json_field("resume_recent_event", resume_recent_event) <> ", " <> LoopJson.json_field("resume_roles", LoopUtils.join_csv(resume_roles)) <> ", " <> LoopJson.json_field("resume_events", LoopUtils.join_csv(resume_events)))
  end

  defp joined_resume_routing_basis(_loop, iter, "explore.parallel") do
    recent_event(iter)
  end

  defp joined_resume_routing_basis(_loop, _iter, emitted_topic) do
    parallel_dispatch_base(emitted_topic)
  end

  defp joined_resume_recent_event(iter, "explore.parallel", _joined_topic) do
    recent_event(iter)
  end

  defp joined_resume_recent_event(_iter, _emitted_topic, joined_topic) do
    joined_topic
  end

  defp joined_resume_roles(_loop, iter, "explore.parallel", _routing_basis) do
    allowed_roles(iter)
  end

  defp joined_resume_roles(loop, _iter, _emitted_topic, routing_basis) do
    LoopTopology.suggested_roles(topology(loop), routing_basis)
  end

  defp joined_resume_events(_loop, iter, "explore.parallel", _routing_basis) do
    allowed_events(iter)
  end

  defp joined_resume_events(loop, _iter, _emitted_topic, routing_basis) do
    LoopTopology.allowed_events(topology(loop), routing_basis)
  end

  defp render_branch_outcomes_csv([]) do
    ""
  end

  defp render_branch_outcomes_csv([branch]) do
    Map.get(branch, :branch_id, "") <> ":" <> Map.get(branch, :stop_reason, "")
  end

  defp render_branch_outcomes_csv([branch | rest]) do
    Map.get(branch, :branch_id, "") <> ":" <> Map.get(branch, :stop_reason, "") <> "," <> render_branch_outcomes_csv(rest)
  end

  defp write_wave_spec(wave_dir, wave_id, emitted_topic, iter, objectives) do
    content = Markdown.heading(1, "Parallel Wave " <> wave_id) <> "\n\n" <>
      "Trigger: " <> Markdown.code(emitted_topic) <> "\n" <>
      "Opening recent event: " <> Markdown.code(recent_event(iter)) <> "\n" <>
      "Opening roles: " <> LoopUtils.list_text(allowed_roles(iter)) <> "\n" <>
      "Opening events: " <> LoopUtils.list_text(allowed_events(iter)) <> "\n\n" <>
      Markdown.heading(2, "Branch Objectives") <> "\n" <> Markdown.bullet_list(objectives)
    System.write_text(Path.join(wave_dir, "spec.md"), content)
  end

  defp write_wave_join(wave_dir, wave_id, emitted_topic, objectives, branch_results, opening_recent_event, opening_roles, opening_events) do
    content = Markdown.heading(1, "Parallel Join " <> wave_id) <> "\n\n" <>
      "Trigger: " <> Markdown.code(emitted_topic) <> "\n" <>
      "Opening recent event: " <> Markdown.code(opening_recent_event) <> "\n" <>
      "Opening roles: " <> LoopUtils.list_text(opening_roles) <> "\n" <>
      "Opening events: " <> LoopUtils.list_text(opening_events) <> "\n\n" <>
      Markdown.heading(2, "Objectives") <> "\n" <> Markdown.bullet_list(objectives) <> "\n\n" <>
      Markdown.heading(2, "Branch Results") <> "\n" <> Markdown.bullet_list(wave_branch_result_items(branch_results, []))
    System.write_text(Path.join(wave_dir, "join.md"), content)
  end

  defp wave_branch_result_items([], acc) do
    Enum.reverse(acc)
  end

  defp wave_branch_result_items([branch | rest], acc) do
    text = Markdown.code(Map.get(branch, :branch_id, "")) <> ": " <> Map.get(branch, :stop_reason, "")
    wave_branch_result_items(rest, [text] ++ acc)
  end

  defp render_branch_objective(objective, emitted_topic, routing_event, branch_roles, branch_events) do
    Markdown.heading(1, "Branch Objective") <> "\n\n" <>
      "Trigger: " <> Markdown.code(emitted_topic) <> "\n" <>
      "Routing event: " <> Markdown.code(routing_event) <> "\n" <>
      "Roles: " <> LoopUtils.list_text(branch_roles) <> "\n" <>
      "Allowed events: " <> LoopUtils.list_text(branch_events) <> "\n\n" <>
      objective <> "\n"
  end

  defp render_branch_prompt(loop, objective, emitted_topic, routing_event, branch_roles, branch_events) do
    "Parallel branch objective:\n" <> objective <> "\n\n" <>
      "Parent objective:\n" <> objective(loop) <> "\n\n" <>
      "Wave trigger: " <> Markdown.code(emitted_topic) <> "\n" <>
      "Branch routing event: " <> Markdown.code(routing_event) <> "\n" <>
      "Suggested roles: " <> LoopUtils.list_text(branch_roles) <> "\n" <>
      "Allowed events: " <> LoopUtils.list_text(branch_events) <> "\n" <>
      "Work only on this branch objective. Branch state is isolated; do not assume you can control parent routing directly.\n"
  end

  defp render_branch_result(result) do
    Markdown.heading(1, "Branch Result") <> "\n\n" <>
      "Stop reason: " <> Markdown.code(Map.get(result, :stop_reason, "unknown")) <> "\n" <>
      "Routing event: " <> Markdown.code(Map.get(result, :routing_event, "")) <> "\n" <>
      "Allowed events: " <> LoopUtils.list_text(Map.get(result, :allowed_events, [])) <> "\n\n" <>
      Markdown.heading(2, "Output") <> "\n\n" <> Map.get(result, :output, "") <> "\n"
  end

  defp completed_via_event(topics, completion_event, required_events) do
    LoopUtils.list_contains(topics, completion_event) and all_required_events_seen(topics, required_events)
  end

  defp completed_via_promise(_output, "") do
    false
  end

  defp completed_via_promise(output, completion_promise) do
    String.contains(output, completion_promise)
  end

  defp all_required_events_seen(_topics, []) do
    true
  end

  defp all_required_events_seen(topics, [event | rest]) do
    case LoopUtils.list_contains(topics, event) do
      true -> all_required_events_seen(topics, rest)
      _ -> false
    end
  end

  defp stop_max_iterations(loop, iteration) do
    completed_iterations = max_iteration_stop_count(iteration)
    limit = max_iterations(loop)
    log(loop, :warn, "loop stop reason=max_iterations completed_iterations=" <> to_string(completed_iterations) <> " max_iterations=" <> to_string(limit))
    append_event(journal_file(loop), run_id(loop), "", "loop.stop", LoopJson.json_field("reason", "max_iterations") <> ", " <> LoopJson.json_field("completed_iterations", to_string(completed_iterations)) <> ", " <> LoopJson.json_field("stopped_before_iteration", to_string(iteration)) <> ", " <> LoopJson.json_field("max_iterations", to_string(limit)))

    %{iterations: completed_iterations, stop_reason: "max_iterations"}
  end

  defp max_iteration_stop_count(iteration) do
    case iteration <= 1 do
      true -> 0
      _ -> iteration - 1
    end
  end

  defp stop_backend_failed(loop, iteration, output) do
    log(loop, :error, "loop stop reason=backend_failed iteration=" <> to_string(iteration))
    print_failure_diagnostic(output)
    tail = last_n_chars(output, 500)
    append_event(journal_file(loop), run_id(loop), to_string(iteration), "loop.stop", LoopJson.json_field("reason", "backend_failed") <> ", " <> LoopJson.json_field("iteration", to_string(iteration)) <> ", " <> LoopJson.json_field("output_tail", tail))

    %{iterations: iteration, stop_reason: "backend_failed"}
  end

  defp stop_backend_timeout(loop, iteration, output) do
    log(loop, :error, "loop stop reason=backend_timeout iteration=" <> to_string(iteration))
    print_failure_diagnostic(output)
    tail = last_n_chars(output, 500)
    append_event(journal_file(loop), run_id(loop), to_string(iteration), "loop.stop", LoopJson.json_field("reason", "backend_timeout") <> ", " <> LoopJson.json_field("iteration", to_string(iteration)) <> ", " <> LoopJson.json_field("output_tail", tail))

    %{iterations: iteration, stop_reason: "backend_timeout"}
  end

  defp complete_loop(loop, iteration, reason) do
    log(loop, :info, "loop complete reason=" <> reason)
    append_event(journal_file(loop), run_id(loop), to_string(iteration), "loop.complete", LoopJson.json_field("reason", reason))

    %{iterations: iteration, stop_reason: reason}
  end

  defp append_loop_start(loop) do
    append_event(journal_file(loop), run_id(loop), "", "loop.start", LoopJson.json_field("max_iterations", to_string(max_iterations(loop))) <> ", " <> LoopJson.json_field("completion_promise", completion_promise(loop)) <> ", " <> LoopJson.json_field("completion_event", completion_event(loop)) <> ", " <> LoopJson.json_field("review_every", to_string(review_every(loop))) <> ", " <> LoopJson.json_field("objective", objective(loop)))
  end

  defp append_iteration_start(loop, iter) do
    append_event(journal_file(loop), run_id(loop), iteration_string(iter), "iteration.start", LoopJson.json_field("recent_event", recent_event(iter)) <> ", " <> LoopJson.json_field("suggested_roles", LoopUtils.join_csv(allowed_roles(iter))) <> ", " <> LoopJson.json_field("allowed_events", LoopUtils.join_csv(allowed_events(iter))) <> ", " <> LoopJson.json_field("backpressure", backpressure(iter)) <> ", " <> LoopJson.json_field("prompt", prompt_text(iter)))
  end

  defp append_backend_start(loop, iter) do
    append_event(journal_file(loop), run_id(loop), iteration_string(iter), "backend.start", LoopJson.json_field("backend_kind", backend_kind(loop)) <> ", " <> LoopJson.json_field("command", backend_command(loop)) <> ", " <> LoopJson.json_field("prompt_mode", backend_prompt_mode(loop)) <> ", " <> LoopJson.json_field("timeout_ms", to_string(backend_timeout_ms(loop))))
  end

  defp append_backend_finish(loop, iter, output, exit_code, timed_out) do
    append_event(journal_file(loop), run_id(loop), iteration_string(iter), "backend.finish", LoopJson.json_field("exit_code", to_string(exit_code)) <> ", " <> LoopJson.json_field_raw("timed_out", LoopJson.json_bool(timed_out)) <> ", " <> LoopJson.json_field("output", output))
  end

  defp append_iteration_finish(loop, iter, output, exit_code, timed_out, elapsed_s) do
    append_event(journal_file(loop), run_id(loop), iteration_string(iter), "iteration.finish", LoopJson.json_field("exit_code", to_string(exit_code)) <> ", " <> LoopJson.json_field_raw("timed_out", LoopJson.json_bool(timed_out)) <> ", " <> LoopJson.json_field("elapsed_s", to_string(elapsed_s)) <> ", " <> LoopJson.json_field("output", output))
  end

  defp resolve_prompt(project_dir, config, prompt_override) do
    case prompt_override do
      nil -> prompt_from_config(project_dir, config)
      prompt -> prompt
    end
  end

  defp prompt_from_config(project_dir, config) do
    inline_prompt = LoopConfig.get(config, "event_loop.prompt", "")

    case inline_prompt do
      "" -> prompt_from_file(project_dir, config)
      _ -> inline_prompt
    end
  end

  defp prompt_from_file(project_dir, config) do
    prompt_file = LoopConfig.get(config, "event_loop.prompt_file", "")

    case prompt_file do
      "" -> "Do the task and publish the completion event when finished."
      _ -> read_prompt_file(project_dir, prompt_file)
    end
  end

  defp read_prompt_file(project_dir, prompt_file) do
    full_path = Path.join(project_dir, prompt_file)

    case System.path_exists(full_path) do
      true -> System.read_text(full_path)
      _ -> "Do the task and publish the completion event when finished."
    end
  end

  defp resolve_review_prompt(project_dir, config) do
    inline_prompt = LoopConfig.get(config, "review.prompt", "")

    case inline_prompt do
      "" -> read_optional_project_file(project_dir, LoopConfig.get(config, "review.prompt_file", "hyperagent.md"))
      _ -> inline_prompt
    end
  end

  defp read_optional_project_file(_project_dir, "") do
    ""
  end

  defp read_optional_project_file(project_dir, relative_path) do
    full_path = Path.join(project_dir, relative_path)

    case System.path_exists(full_path) do
      true -> System.read_text(full_path)
      _ -> ""
    end
  end

  defp resolve_review_every(config, topology) do
    configured = LoopConfig.get_int(config, "review.every_iterations", 0)

    case configured > 0 do
      true -> configured
      _ -> default_review_every(topology)
    end
  end

  defp default_review_every(topology) do
    count = LoopTopology.role_count(topology)

    case count > 0 do
      true -> count
      _ -> 1
    end
  end

  defp truthy_setting("false") do
    false
  end

  defp truthy_setting("0") do
    false
  end

  defp truthy_setting("") do
    false
  end

  defp truthy_setting(_value) do
    true
  end

  defp ensure_layout(state_dir) do
    System.ensure_dir(state_dir)
  end

  defp install_runtime_tools(loop) do
    install_emit_tool(loop)
    install_pi_adapter_tool(loop)
  end

  defp install_emit_tool(loop) do
    System.write_text(tool_path(loop), emit_tool_script(loop))
    System.run("chmod +x " <> LoopUtils.shell_quote(tool_path(loop)))
  end

  defp install_pi_adapter_tool(loop) do
    System.write_text(pi_adapter_path(loop), pi_adapter_script(loop))
    System.run("chmod +x " <> LoopUtils.shell_quote(pi_adapter_path(loop)))
  end

  defp emit_tool_script(loop) do
    "#!/bin/sh\n" <> "set -eu\n" <> "export MINILOOPS_PROJECT_DIR=" <> LoopUtils.shell_quote(project_dir(loop)) <> "\n" <> "export MINILOOPS_JOURNAL_FILE=" <> LoopUtils.shell_quote(journal_file(loop)) <> "\n" <> "export MINILOOPS_EVENTS_FILE=" <> LoopUtils.shell_quote(journal_file(loop)) <> "\n" <> "export MINILOOPS_MEMORY_FILE=" <> LoopUtils.shell_quote(memory_file(loop)) <> "\n" <> "export MINILOOPS_RUN_ID=" <> LoopUtils.shell_quote(run_id(loop)) <> "\n" <> "export MINILOOPS_COMPLETION_EVENT=" <> LoopUtils.shell_quote(completion_event(loop)) <> "\n" <> "export MINILOOPS_REQUIRED_EVENTS=" <> LoopUtils.shell_quote(LoopUtils.join_csv(required_events(loop))) <> "\n" <> "export MINILOOPS_BIN=" <> LoopUtils.shell_quote(tool_path(loop)) <> "\n" <> "stdout_file=$(mktemp)\n" <> "stderr_file=$(mktemp)\n" <> "cleanup() {\n" <> "  rm -f \"$stdout_file\" \"$stderr_file\"\n" <> "}\n" <> "trap cleanup EXIT\n" <> "if " <> self_command(loop) <> " \"$@\" >\"$stdout_file\" 2>\"$stderr_file\"; then\n" <> "  status=0\n" <> "else\n" <> "  status=$?\n" <> "fi\n" <> "cat \"$stderr_file\" >&2\n" <> "if [ \"${1:-}\" = \"emit\" ]; then\n" <> "  inner=$(sed -n 's/^%{:exit_code => \\([0-9][0-9]*\\),.*$/\\1/p' \"$stdout_file\" | tail -n 1)\n" <> "  if [ -n \"$inner\" ]; then\n" <> "    exit \"$inner\"\n" <> "  fi\n" <> "fi\n" <> "cat \"$stdout_file\"\n" <> "exit \"$status\"\n"
  end

  defp pi_adapter_script(loop) do
    "#!/bin/sh\n" <> "set -eu\n" <> "exec " <> self_command(loop) <> " pi-adapter \"$@\"\n"
  end

  defp render_iteration_prompt_text(loop, iteration, recent_event, allowed_roles, allowed_events, backpressure, invalid_count, scratchpad_text, memory_text, memory_stats) do
    "You are inside a bare-minimal miniloops harness.\n\n" <>
    harness_instructions_text(loop) <>
    context_pressure_text(memory_stats, invalid_count) <>
    backpressure_text(backpressure) <> "Objective:\n" <> objective(loop) <> "\n\n" <>
    memory_text_block(memory_text) <>
    LoopTopology.render_with_context(topology(loop), recent_event, allowed_roles, allowed_events) <> "\n" <>
    parallel_prompt_text(loop, allowed_events) <>
    "Iteration: #{iteration}/#{max_iterations(loop)}\n" <> "Log level: #{log_level_name(loop)}\n" <> "Completion event: #{completion_event(loop)}\n" <> "Completion promise fallback: #{completion_promise(loop)}\n" <> "Required events: #{required_events_text(required_events(loop))}\n" <> "Loop-owned working files belong under: #{state_dir(loop)}\n" <> "Do not leave loop-owned artifacts at the repo root. Use paths under #{state_dir(loop)} such as #{state_dir(loop)}/progress.md or #{state_dir(loop)}/logs/.\n" <> "Suggested next roles now: #{LoopUtils.list_text(allowed_roles)}\n" <> "Allowed next events now: #{LoopUtils.list_text(allowed_events)}\n" <> "Event tool: " <> tool_path(loop) <> "\n\n" <> "Current scratchpad:\n" <> empty_fallback(scratchpad_text) <> "\n\n" <> "Use the event tool to publish your allowed handoff or completion event.\n" <> "Examples:\n" <>
    tool_path(loop) <> " emit <allowed-topic> \"brief handoff summary\"\n" <>
    tool_path(loop) <> " emit " <> completion_event(loop) <> " \"brief completion summary\"\n" <>
    tool_path(loop) <> " memory add learning \"durable lesson\"\n" <>
    tool_path(loop) <> " memory add preference Workflow \"short preference note\"\n\n" <> "Backpressure rule: if you emit an event outside the allowed next-event set, the loop will reject that handoff and ask you to re-route.\n" <> "Prompt/output/scratchpad/memory are projections or stores you can inspect with `" <> tool_path(loop) <> " inspect prompt #{iteration} --format md`, `" <> tool_path(loop) <> " inspect scratchpad --format md`, and `" <> tool_path(loop) <> " inspect memory --format md`.\n" <> "Plain text alone does not publish an event. Prefer the event tool over the stdout completion promise.\n"
  end

  defp parallel_prompt_text(loop, allowed_events) do
    case parallel_prompt_enabled(loop) do
      true -> render_parallel_prompt(loop, allowed_events)
      _ -> ""
    end
  end

  defp parallel_prompt_enabled(loop) do
    parallel_enabled(loop) and not branch_mode(loop)
  end

  defp render_parallel_prompt(loop, allowed_events) do
    dispatch_events = parallel_dispatch_prompt_events(allowed_events, completion_event(loop), [])

    "Structured parallelism:\n" <>
    "- `explore.parallel` is available for exploratory self-loop fan-out before you choose the real next event.\n" <>
    parallel_dispatch_prompt_line(dispatch_events) <>
    "- Payloads must be a markdown bullet list or numbered list with 1.." <> to_string(parallel_max_branches(loop)) <> " distinct branch objectives.\n" <>
    "- Use fan-out only when branches are concrete, independently useful, and worth the barrier cost; keep one active wave at a time.\n" <>
    "- Branches run in isolated state under `" <> state_dir(loop) <> "/waves/`; only the harness may emit `*.parallel.joined` to resume the parent after the join barrier.\n\n"
  end

  defp parallel_dispatch_prompt_events([], _completion_event, acc) do
    Enum.reverse(acc)
  end

  defp parallel_dispatch_prompt_events([event | rest], completion_event, acc) do
    case parallel_dispatch_prompt_candidate(event, completion_event) do
      true -> parallel_dispatch_prompt_events(rest, completion_event, [event <> ".parallel"] ++ acc)
      _ -> parallel_dispatch_prompt_events(rest, completion_event, acc)
    end
  end

  defp parallel_dispatch_prompt_candidate(event, completion_event) do
    not (event == completion_event or coordination_topic(event) or core_system_topic(event) or parallel_topic(event))
  end

  defp parallel_dispatch_prompt_line([]) do
    "- Dispatch fan-out is available as `<allowed-event>.parallel` for currently allowed normal handoff events.\n"
  end

  defp parallel_dispatch_prompt_line(dispatch_events) do
    "- Dispatch fan-out is available now via `<allowed-event>.parallel`: " <> render_parallel_prompt_events(dispatch_events) <> ".\n"
  end

  defp render_parallel_prompt_events([]) do
    "(none)"
  end

  defp render_parallel_prompt_events([event]) do
    "`" <> event <> "`"
  end

  defp render_parallel_prompt_events([event | rest]) do
    "`" <> event <> "`, " <> render_parallel_prompt_events(rest)
  end

  defp harness_instructions_text(loop) do
    case harness_instructions(loop) do
      "" -> ""
      text -> "Live harness instructions:\n" <> text <> "\n\n"
    end
  end

  defp review_instructions_text(loop) do
    case review_prompt(loop) do
      "" -> ""
      text -> "Additional hyperagent instructions:\n" <> text <> "\n\n"
    end
  end

  defp context_pressure_text(memory_stats, invalid_count) do
    "Context pressure:\n" <>
    "- Memory: " <> memory_pressure_summary(memory_stats) <> "\n" <>
    "- Invalid emits this run: " <> to_string(invalid_count) <> invalid_emit_hint(invalid_count) <> "\n" <>
    context_pressure_recommendation(memory_stats, invalid_count)
  end

  defp memory_pressure_summary(memory_stats) do
    rendered_chars = Map.get(memory_stats, :rendered_chars, 0)
    budget_chars = Map.get(memory_stats, :budget_chars, 0)
    total_entries = Map.get(memory_stats, :total_entries, 0)
    preferences = Map.get(memory_stats, :preferences, 0)
    learnings = Map.get(memory_stats, :learnings, 0)
    meta = Map.get(memory_stats, :meta, 0)

    case Map.get(memory_stats, :truncated, false) do
      true -> to_string(rendered_chars) <> "/" <> to_string(budget_chars) <> " chars across " <> to_string(total_entries) <> " entries (" <> to_string(preferences) <> " preferences, " <> to_string(learnings) <> " learnings, " <> to_string(meta) <> " meta) — truncated by " <> to_string(rendered_chars - budget_chars) <> " chars"
      _ -> memory_pressure_summary_within_budget(rendered_chars, budget_chars, total_entries, preferences, learnings, meta)
    end
  end

  defp memory_pressure_summary_within_budget(rendered_chars, budget_chars, total_entries, preferences, learnings, meta) do
    case budget_chars <= 0 do
      true -> to_string(rendered_chars) <> " chars across " <> to_string(total_entries) <> " entries (" <> to_string(preferences) <> " preferences, " <> to_string(learnings) <> " learnings, " <> to_string(meta) <> " meta); prompt budget disabled"
      _ -> to_string(rendered_chars) <> "/" <> to_string(budget_chars) <> " chars across " <> to_string(total_entries) <> " entries (" <> to_string(preferences) <> " preferences, " <> to_string(learnings) <> " learnings, " <> to_string(meta) <> " meta)"
    end
  end

  defp invalid_emit_hint(0) do
    ""
  end

  defp invalid_emit_hint(_invalid_count) do
    " — routing is currently under backpressure"
  end

  defp context_pressure_recommendation(memory_stats, invalid_count) do
    case Map.get(memory_stats, :truncated, false) do
      true -> "- Recommendation: consolidate stale or duplicate context before adding new memory, and re-route using the allowed-event set when needed.\n\n"
      _ -> context_pressure_recommendation_from_invalid_count(invalid_count)
    end
  end

  defp context_pressure_recommendation_from_invalid_count(invalid_count) do
    case invalid_count > 0 do
      true -> "- Recommendation: consolidate stale or duplicate context before adding new memory, and re-route using the allowed-event set when needed.\n\n"
      _ -> "\n"
    end
  end

  defp memory_text_block("") do
    ""
  end

  defp memory_text_block(text) do
    text <> "\n"
  end

  defp max_review_prompt_iteration(run_lines) do
    latest_prompt_iteration_from_lines(run_lines, 1)
  end

  defp latest_prompt_iteration_from_lines([], current) do
    current
  end

  defp latest_prompt_iteration_from_lines([line | rest], current) do
    next =
    case extract_topic(line) do
      "iteration.start" -> max_iteration_value(current, extract_iteration(line))
      _ -> current
    end

    latest_prompt_iteration_from_lines(rest, next)
  end

  defp max_iteration_value(current, "") do
    current
  end

  defp max_iteration_value(current, value) do
    parsed = String.to_integer(value)

    case parsed > current do
      true -> parsed
      _ -> current
    end
  end

  defp backpressure_text("") do
    ""
  end

  defp backpressure_text(text) do
    "Backpressure:\n" <> text <> "\n\n"
  end

  defp required_events_text([]) do
    "(none)"
  end

  defp required_events_text(required_events) do
    LoopUtils.join_csv(required_events)
  end

  defp empty_fallback("") do
    "(empty)"
  end

  defp empty_fallback(text) do
    text
  end

  defp build_backend_command(loop, iter) do
    build_process_command(loop, backend_spec(loop), prompt_text(iter), runtime_env_lines(loop, iteration_string(iter), recent_event(iter), LoopUtils.join_csv(allowed_roles(iter)), LoopUtils.join_csv(allowed_events(iter)), ""))
  end

  defp build_review_command(loop, iteration, review_prompt) do
    build_process_command(loop, review_spec(loop), review_prompt, runtime_env_lines(loop, to_string(iteration), "loop.start", "review", "__hyperreview_disabled__", "hyperagent"))
  end

  defp build_process_command(loop, spec, prompt, runtime_env) do
    env_lines = runtime_env <> "export MINILOOPS_PROMPT=" <> LoopUtils.shell_quote(prompt) <> "\n"
    child_command = case process_kind(spec) do
      "pi" -> build_pi_adapter_invocation(loop, spec)
      _ -> build_command_invocation(spec, prompt)
    end

    env_lines <> wrap_process_invocation(child_command)
  end

  defp build_pi_adapter_invocation(loop, spec) do
    LoopUtils.shell_words([pi_adapter_path(loop), process_command(spec)] ++ process_args(spec))
  end

  defp build_command_invocation(spec, prompt) do
    argv = LoopUtils.shell_words([process_command(spec)] ++ process_args(spec))

    case process_prompt_mode(spec) do
      "stdin" -> "printf '%s' " <> LoopUtils.shell_quote(prompt) <> " | " <> argv
      _ -> LoopUtils.shell_words([process_command(spec)] ++ process_args(spec) ++ [prompt])
    end
  end

  defp wrap_process_invocation(command) do
    "miniloops_child_pid=''\n" <>
    "miniloops_cleanup() {\n" <>
    "  if [ -n \"$miniloops_child_pid\" ]; then\n" <>
    "    kill \"$miniloops_child_pid\" 2>/dev/null || true\n" <>
    "    wait \"$miniloops_child_pid\" 2>/dev/null || true\n" <>
    "  fi\n" <>
    "}\n" <>
    "trap 'miniloops_cleanup; exit 130' INT TERM\n" <>
    "(\n" <> command <> "\n" <>
    ") &\n" <>
    "miniloops_child_pid=$!\n" <>
    "wait \"$miniloops_child_pid\"\n" <>
    "miniloops_status=$?\n" <>
    "trap - INT TERM\n" <>
    "exit \"$miniloops_status\"\n"
  end

  defp runtime_env_lines(loop, iteration, recent_event, allowed_roles, allowed_events, review_mode) do
    "export MINILOOPS_RUN_ID=" <> LoopUtils.shell_quote(run_id(loop)) <> "\n" <>
    "export MINILOOPS_ITERATION=" <> LoopUtils.shell_quote(iteration) <> "\n" <>
    runtime_env_line("MINILOOPS_REVIEW_MODE", review_mode) <>
    "export MINILOOPS_LOG_LEVEL=" <> LoopUtils.shell_quote(log_level_name(loop)) <> "\n" <>
    "export MINILOOPS_COMPLETION_PROMISE=" <> LoopUtils.shell_quote(completion_promise(loop)) <> "\n" <>
    "export MINILOOPS_COMPLETION_EVENT=" <> LoopUtils.shell_quote(completion_event(loop)) <> "\n" <>
    "export MINILOOPS_STATE_DIR=" <> LoopUtils.shell_quote(state_dir(loop)) <> "\n" <>
    "export MINILOOPS_PROJECT_DIR=" <> LoopUtils.shell_quote(project_dir(loop)) <> "\n" <>
    "export MINILOOPS_JOURNAL_FILE=" <> LoopUtils.shell_quote(journal_file(loop)) <> "\n" <>
    "export MINILOOPS_EVENTS_FILE=" <> LoopUtils.shell_quote(journal_file(loop)) <> "\n" <>
    "export MINILOOPS_MEMORY_FILE=" <> LoopUtils.shell_quote(memory_file(loop)) <> "\n" <>
    "export MINILOOPS_REQUIRED_EVENTS=" <> LoopUtils.shell_quote(LoopUtils.join_csv(required_events(loop))) <> "\n" <>
    "export MINILOOPS_RECENT_EVENT=" <> LoopUtils.shell_quote(recent_event) <> "\n" <>
    "export MINILOOPS_ALLOWED_ROLES=" <> LoopUtils.shell_quote(allowed_roles) <> "\n" <>
    "export MINILOOPS_ALLOWED_EVENTS=" <> LoopUtils.shell_quote(allowed_events) <> "\n" <>
    "export MINILOOPS_BIN=" <> LoopUtils.shell_quote(tool_path(loop)) <> "\n"
  end

  defp runtime_env_line(_name, "") do
    ""
  end

  defp runtime_env_line(name, value) do
    "export " <> name <> "=" <> LoopUtils.shell_quote(value) <> "\n"
  end

  defp render_review_prompt_text(loop, iteration, run_lines) do
    scratchpad_text = render_run_scratchpad_prompt(run_lines)
    memory_text = LoopMemory.render_file(memory_file(loop), memory_budget_chars(loop))
    memory_stats = LoopMemory.stats_file(memory_file(loop), memory_budget_chars(loop))
    routing = iteration_routing_context(topology(loop), run_lines)
    recent_event = Map.get(routing, :recent_event, "loop.start")
    backpressure = latest_invalid_note(run_lines, "")
    invalid_count = invalid_event_count(run_lines, 0)
    latest_iteration = to_string(max_review_prompt_iteration(run_lines))

    "You are the hyperagent meta-reviewer for this loop.\n\n" <> "Your job is to improve the loop itself, not to finish the task directly.\n" <> "You may make bounded hygiene edits to runtime-facing loop files when that will improve the next iterations.\n" <> "Safe edit targets include `miniloops.toml`, `topology.toml`, `harness.md`, `hyperagent.md`, `roles/*.md`, `" <> state_dir(loop) <> "/context.md`, `" <> state_dir(loop) <> "/plan.md`, `" <> state_dir(loop) <> "/progress.md`, `" <> state_dir(loop) <> "/logs/`, and `" <> state_dir(loop) <> "/docs/*.md`.\n" <> "Keep loop-owned artifacts under `" <> state_dir(loop) <> "/`; do not leave loop-owned working files at the repo root.\n" <> "Use `" <> tool_path(loop) <> " memory add ...` for short durable lessons or operator notes that should persist across turns.\n" <> "Do not edit app/product source code, tests, package manifests, generated state under `" <> state_dir(loop) <> "/`, or journal history during review.\n" <> "The scratchpad is projected from journal history, so do not try to edit it directly; instead tighten prompts, working files, or archived context so future iterations stay concise.\n" <> "Do not emit normal loop events during review.\n\n" <>
    review_instructions_text(loop) <>
    context_pressure_text(memory_stats, invalid_count) <>
    backpressure_text(backpressure) <>
    memory_text_block(memory_text) <> "Review trigger iteration: #{iteration}\n" <> "Latest routing event: " <> recent_event <> "\n\n" <>
    LoopTopology.render_with_context(topology(loop), recent_event, Map.get(routing, :allowed_roles, []), Map.get(routing, :allowed_events, [])) <> "\n" <> "Current scratchpad:\n" <> empty_fallback(scratchpad_text) <> "\n\n" <> "Useful commands:\n" <>
    tool_path(loop) <> " inspect scratchpad --format md\n" <>
    tool_path(loop) <> " inspect memory --format md\n" <>
    tool_path(loop) <> " inspect prompt " <> latest_iteration <> " --format md\n" <>
    tool_path(loop) <> " inspect output " <> latest_iteration <> " --format text\n\n" <> "If no improvements are needed, store a short learning explaining why and exit cleanly.\n"
  end

  defp resolve_emit_journal_file(project_dir) do
    case System.env("MINILOOPS_JOURNAL_FILE") do
      nil -> resolve_emit_journal_file_from_events_env(project_dir)
      path -> resolve_emit_journal_file_value(project_dir, path)
    end
  end

  defp resolve_emit_journal_file_from_events_env(project_dir) do
    case System.env("MINILOOPS_EVENTS_FILE") do
      nil -> LoopConfig.resolve_journal_file(project_dir)
      path -> resolve_emit_journal_file_value(project_dir, path)
    end
  end

  defp resolve_emit_journal_file_value(project_dir, "") do
    LoopConfig.resolve_journal_file(project_dir)
  end

  defp resolve_emit_journal_file_value(_project_dir, path) do
    path
  end

  defp accept_emit(journal_file, topic, payload, validation) do
    append_agent_event(journal_file, Map.get(validation, :run_id, ""), Map.get(validation, :iteration, ""), topic, payload)
    IO.puts("emitted #{topic}")
    System.run("true")
  end

  defp reject_emit(journal_file, topic, validation) do
    message = invalid_emit_message(topic, validation)
    append_invalid_event(journal_file, Map.get(validation, :run_id, ""), Map.get(validation, :iteration, ""), Map.get(validation, :recent_event, "loop.start"), topic, Map.get(validation, :allowed_roles, []), Map.get(validation, :allowed_events, []))
    System.run("printf '%s\\n' " <> LoopUtils.shell_quote(message) <> " >&2; false")
  end

  defp invalid_emit_message(topic, validation) do
    "invalid event `" <> topic <> "`; recent event: `" <> Map.get(validation, :recent_event, "loop.start") <> "`; suggested roles: " <> LoopUtils.list_text(Map.get(validation, :allowed_roles, [])) <> "; allowed next events: " <> LoopUtils.list_text(Map.get(validation, :allowed_events, []))
  end

  defp emit_validation_context(project_dir, journal_file) do
    run_id = resolve_emit_run_id(journal_file)
    config = LoopConfig.load_project(project_dir)
    topology = LoopTopology.load(project_dir)
    completion_event = LoopTopology.completion_event(topology, LoopConfig.get(config, "event_loop.completion_event", "task.complete"))

    %{run_id: run_id, iteration: resolve_emit_iteration(journal_file, run_id), recent_event: emit_recent_event(), allowed_roles: env_csv_list("MINILOOPS_ALLOWED_ROLES"), allowed_events: env_csv_list("MINILOOPS_ALLOWED_EVENTS"), parallel_enabled: truthy_setting(LoopConfig.get(config, "parallel.enabled", "false")), completion_event: completion_event}
  end

  defp resolve_emit_run_id(journal_file) do
    case System.env("MINILOOPS_RUN_ID") do
      nil -> latest_run_id(journal_file)
      "" -> latest_run_id(journal_file)
      value -> value
    end
  end

  defp resolve_emit_iteration(journal_file, run_id) do
    case System.env("MINILOOPS_ITERATION") do
      nil -> latest_iteration_for_run(journal_file, run_id)
      "" -> latest_iteration_for_run(journal_file, run_id)
      value -> value
    end
  end

  defp emit_recent_event() do
    case System.env("MINILOOPS_RECENT_EVENT") do
      nil -> "loop.start"
      "" -> "loop.start"
      value -> value
    end
  end

  defp env_csv_list(name) do
    case System.env(name) do
      nil -> []
      "" -> []
      value -> LoopUtils.split_csv(value)
    end
  end

  defp append_invalid_event(journal_file, run_id, iteration, recent_event, emitted_topic, allowed_roles, allowed_events) do
    append_event(journal_file, run_id, iteration, "event.invalid", LoopJson.json_field("recent_event", recent_event) <> ", " <> LoopJson.json_field("emitted", emitted_topic) <> ", " <> LoopJson.json_field("suggested_roles", LoopUtils.join_csv(allowed_roles)) <> ", " <> LoopJson.json_field("allowed_events", LoopUtils.join_csv(allowed_events)))
  end

  defp ensure_render_run_id(journal_file) do
    run_id = render_run_id(journal_file)

    case run_id do
      "" -> ""
      value -> value
    end
  end

  defp render_run_id(journal_file) do
    case System.env("MINILOOPS_RUN_ID") do
      nil -> latest_run_id(journal_file)
      "" -> latest_run_id(journal_file)
      value -> value
    end
  end

  defp latest_invalid_note([], note) do
    note
  end

  defp latest_invalid_note([line | rest], note) do
    topic = extract_topic(line)

    case topic do
      "event.invalid" -> latest_invalid_note(rest, invalid_note_from_line(line))
      _ -> latest_invalid_note(rest, clear_note_after_valid_emit(topic, note))
    end
  end

  defp invalid_event_count([], count) do
    count
  end

  defp invalid_event_count([line | rest], count) do
    next =
    case extract_topic(line) do
      "event.invalid" -> count + 1
      _ -> count
    end

    invalid_event_count(rest, next)
  end

  defp clear_note_after_valid_emit(topic, note) do
    case system_topic(topic) do
      true -> note
      _ -> ""
    end
  end

  defp invalid_note_from_line(line) do
    "Emitted `" <> extract_field(line, "emitted") <> "` after `" <> extract_field(line, "recent_event") <> "`.\n" <> "Suggested roles: " <> empty_list_text(extract_field(line, "suggested_roles")) <> "\n" <> "Allowed next events: " <> empty_list_text(extract_field(line, "allowed_events")) <> "\n" <> "Re-emit using one of the allowed events above."
  end

  defp empty_list_text("") do
    "(none)"
  end

  defp empty_list_text(text) do
    text
  end

  defp iteration_field_for_run(journal_file, run_id, iteration, topic, field) do
    find_iteration_field(read_run_lines(journal_file, run_id), iteration, topic, field, "")
  end

  defp find_iteration_field([], _iteration, _topic, _field, current) do
    current
  end

  defp find_iteration_field([line | rest], iteration, topic, field, current) do
    next =
    case extract_topic(line) == topic do
      true -> match_iteration_field(line, iteration, field, current)
      _ -> current
    end

    find_iteration_field(rest, iteration, topic, field, next)
  end

  defp match_iteration_field(line, iteration, field, current) do
    case extract_iteration(line) == iteration do
      true -> extract_field(line, field)
      _ -> current
    end
  end

  defp read_run_lines(path, run_id) do
    filter_run_lines(read_lines(path), run_id, [])
  end

  defp filter_run_lines([], _run_id, acc) do
    Enum.reverse(acc)
  end

  defp filter_run_lines([line | rest], run_id, acc) do
    case extract_run(line) == run_id do
      true -> filter_run_lines(rest, run_id, [line] ++ acc)
      _ -> filter_run_lines(rest, run_id, acc)
    end
  end

  defp read_lines(path) do
    collect_lines(String.split(read_if_exists(path), LoopUtils.line_sep()), [])
  end

  defp collect_lines([], acc) do
    Enum.reverse(acc)
  end

  defp collect_lines([line | rest], acc) do
    trimmed = String.trim(line)

    case trimmed do
      "" -> collect_lines(rest, acc)
      _ -> collect_lines(rest, [trimmed] ++ acc)
    end
  end

  defp topics_from_lines(lines) do
    collect_topics(lines, [])
  end

  defp collect_topics([], acc) do
    Enum.reverse(acc)
  end

  defp collect_topics([line | rest], acc) do
    topic = extract_topic(line)

    case topic do
      "" -> collect_topics(rest, acc)
      _ -> collect_topics(rest, [topic] ++ acc)
    end
  end

  defp topics_for_iteration(lines, iteration) do
    collect_iteration_topics(lines, iteration, [])
  end

  defp collect_iteration_topics([], _iteration, acc) do
    Enum.reverse(acc)
  end

  defp collect_iteration_topics([line | rest], iteration, acc) do
    topic = extract_topic(line)

    case extract_iteration(line) == iteration do
      true -> collect_iteration_topics(rest, iteration, [topic] ++ acc)
      _ -> collect_iteration_topics(rest, iteration, acc)
    end
  end

  defp lines_for_iteration(lines, iteration) do
    collect_iteration_lines(lines, iteration, [])
  end

  defp collect_iteration_lines([], _iteration, acc) do
    Enum.reverse(acc)
  end

  defp collect_iteration_lines([line | rest], iteration, acc) do
    case extract_iteration(line) == iteration do
      true -> collect_iteration_lines(rest, iteration, [line] ++ acc)
      _ -> collect_iteration_lines(rest, iteration, acc)
    end
  end

  defp latest_agent_event_record([]) do
    %{topic: "", payload: ""}
  end

  defp latest_agent_event_record(lines) do
    latest_agent_event_record_from_list(Enum.reverse(lines))
  end

  defp latest_agent_event_record_from_list([]) do
    %{topic: "", payload: ""}
  end

  defp latest_agent_event_record_from_list([line | rest]) do
    topic = extract_topic(line)

    case system_topic(topic) do
      true -> latest_agent_event_record_from_list(rest)
      _ -> %{topic: topic, payload: extract_field(line, "payload")}
    end
  end

  def render_run_scratchpad_full(lines) do
    render_scratchpad_entries(collect_scratchpad_entries(lines, []))
  end

  defp render_run_scratchpad_prompt(lines) do
    entries = collect_scratchpad_entries(lines, [])
    total = list_length(entries, 0)

    case total <= 4 do
      true -> render_scratchpad_entries(entries)
      _ -> render_compact_scratchpad(entries, total - 4)
    end
  end

  defp collect_scratchpad_entries([], acc) do
    Enum.reverse(acc)
  end

  defp collect_scratchpad_entries([line | rest], acc) do
    next =
    case extract_topic(line) do
      "iteration.finish" -> [scratchpad_entry_map(line)] ++ acc
      _ -> acc
    end

    collect_scratchpad_entries(rest, next)
  end

  defp scratchpad_entry_map(line) do
    %{iteration: extract_iteration(line), exit_code: extract_field(line, "exit_code"), output: extract_field(line, "output")}
  end

  defp render_scratchpad_entries([]) do
    ""
  end

  defp render_scratchpad_entries([entry | rest]) do
    scratchpad_entry_text(entry) <> render_scratchpad_entries(rest)
  end

  defp render_compact_scratchpad(entries, compact_count) do
    compacted = take_n(entries, compact_count, [])
    recent = drop_n(entries, compact_count)

    Markdown.heading(2, "Earlier iterations (compacted)") <> "\n\n" <> Markdown.bullet_list(compact_scratchpad_items(compacted, [])) <> "\n\n" <> render_scratchpad_entries(recent)
  end

  defp compact_scratchpad_items([], acc) do
    Enum.reverse(acc)
  end

  defp compact_scratchpad_items([entry | rest], acc) do
    text = "Iteration " <> Map.get(entry, :iteration, "") <> " exit_code=" <> Map.get(entry, :exit_code, "") <> " — " <> scratchpad_entry_summary(entry)
    compact_scratchpad_items(rest, [text] ++ acc)
  end

  defp scratchpad_entry_text(entry) do
    Markdown.heading(2, "Iteration " <> Map.get(entry, :iteration, "")) <> "\n\n" <> "exit_code=" <> Map.get(entry, :exit_code, "") <> "\n\n" <>
    Map.get(entry, :output, "") <> "\n"
  end

  defp scratchpad_entry_summary(entry) do
    summarize_scratchpad_output(Map.get(entry, :output, ""))
  end

  defp summarize_scratchpad_output(output) do
    summarize_scratchpad_lines(String.split(output, LoopUtils.line_sep()))
  end

  defp summarize_scratchpad_lines([]) do
    "(no output)"
  end

  defp summarize_scratchpad_lines([line | rest]) do
    trimmed = String.trim(line)

    case trimmed do
      "" -> summarize_scratchpad_lines(rest)
      _ -> truncate_scratchpad_summary(trimmed)
    end
  end

  defp truncate_scratchpad_summary(text) do
    case String.length(text) <= 120 do
      true -> text
      _ -> String.slice(text, 0, 120) <> "..."
    end
  end

  defp coordination_from_lines([], acc) do
    render_coordination_state(acc)
  end

  defp coordination_from_lines([line | rest], acc) do
    topic = extract_topic(line)
    next = collect_coordination_event(topic, line, acc)
    coordination_from_lines(rest, next)
  end

  defp collect_coordination_event("issue.discovered", line, acc) do
    entry = %{id: extract_payload_field(line, "id"), summary: extract_payload_field(line, "summary"), disposition: extract_payload_field(line, "disposition"), owner: extract_payload_field(line, "owner")}
    Map.put(acc, :issues, Map.get(acc, :issues, []) ++ [entry])
  end

  defp collect_coordination_event("issue.resolved", line, acc) do
    id = extract_payload_field(line, "id")
    resolution = extract_payload_field(line, "resolution")
    Map.put(acc, :issues, update_issue_resolution(Map.get(acc, :issues, []), id, resolution, []))
  end

  defp collect_coordination_event("slice.started", line, acc) do
    entry = %{id: extract_payload_field(line, "id"), description: extract_payload_field(line, "description"), status: "in-progress"}
    Map.put(acc, :slices, Map.get(acc, :slices, []) ++ [entry])
  end

  defp collect_coordination_event("slice.verified", line, acc) do
    id = extract_payload_field(line, "id")
    Map.put(acc, :slices, update_slice_status(Map.get(acc, :slices, []), id, "verified", []))
  end

  defp collect_coordination_event("slice.committed", line, acc) do
    id = extract_payload_field(line, "id")
    commit_hash = extract_payload_field(line, "commit_hash")
    with_commit = Map.put(acc, :commits, Map.get(acc, :commits, []) ++ [%{slice_id: id, commit_hash: commit_hash}])
    Map.put(with_commit, :slices, update_slice_status(Map.get(with_commit, :slices, []), id, "committed", []))
  end

  defp collect_coordination_event("context.archived", line, acc) do
    entry = %{source_file: extract_payload_field(line, "source_file"), dest_file: extract_payload_field(line, "dest_file"), reason: extract_payload_field(line, "reason")}
    Map.put(acc, :archives, Map.get(acc, :archives, []) ++ [entry])
  end

  defp collect_coordination_event(_topic, _line, acc) do
    acc
  end

  defp extract_payload_field(line, key) do
    payload = extract_field(line, "payload")
    extract_kv_from_payload(payload, key)
  end

  defp extract_kv_from_payload(payload, key) do
    marker = key <> "="
    parts = String.split(payload, marker)
    extract_kv_value(parts)
  end

  defp extract_kv_value([_only]) do
    ""
  end

  defp extract_kv_value([_prefix, rest | _]) do
    first_field_value(rest)
  end

  defp extract_kv_value([]) do
    ""
  end

  defp first_field_value(text) do
    String.trim(first_delimited(String.split(text, ";")))
  end

  defp first_delimited([]) do
    ""
  end

  defp first_delimited([item | _rest]) do
    String.trim(item)
  end

  defp update_issue_resolution([], _id, _resolution, acc) do
    Enum.reverse(acc)
  end

  defp update_issue_resolution([issue | rest], id, resolution, acc) do
    case Map.get(issue, :id, "") == id do
      true -> update_issue_resolution(rest, id, resolution, [Map.put(Map.put(issue, :disposition, "resolved"), :resolution, resolution)] ++ acc)
      _ -> update_issue_resolution(rest, id, resolution, [issue] ++ acc)
    end
  end

  defp update_slice_status([], _id, _status, acc) do
    Enum.reverse(acc)
  end

  defp update_slice_status([slice | rest], id, status, acc) do
    case Map.get(slice, :id, "") == id do
      true -> update_slice_status(rest, id, status, [Map.put(slice, :status, status)] ++ acc)
      _ -> update_slice_status(rest, id, status, [slice] ++ acc)
    end
  end

  defp render_coordination_state(acc) do
    issues = Map.get(acc, :issues, [])
    slices = Map.get(acc, :slices, [])
    commits = Map.get(acc, :commits, [])
    archives = Map.get(acc, :archives, [])

    case issues == [] and slices == [] and commits == [] and archives == [] do
      true -> ""
      _ ->
        Markdown.heading(1, "Coordination State (from journal)") <> "\n\n" <>
        render_coordination_issues(issues) <>
        render_coordination_slices(slices) <>
        render_coordination_commits(commits) <>
        render_coordination_archives(archives)
    end
  end

  defp render_coordination_issues([]) do
    ""
  end

  defp render_coordination_issues(issues) do
    Markdown.heading(2, "Issues") <> "\n" <> Markdown.bullet_list(issue_items(issues, [])) <> "\n\n"
  end

  defp issue_items([], acc) do
    Enum.reverse(acc)
  end

  defp issue_items([issue | rest], acc) do
    disposition = Map.get(issue, :disposition, "open")
    text = "[" <> disposition <> "] " <> Map.get(issue, :id, "?") <> ": " <> Map.get(issue, :summary, "") <> render_issue_resolution(Map.get(issue, :resolution, "")) <> render_issue_owner(Map.get(issue, :owner, ""))
    issue_items(rest, [text] ++ acc)
  end

  defp render_issue_resolution("") do
    ""
  end

  defp render_issue_resolution(resolution) do
    " — " <> resolution
  end

  defp render_issue_owner("") do
    ""
  end

  defp render_issue_owner(owner) do
    " (owner: " <> owner <> ")"
  end

  defp render_coordination_slices([]) do
    ""
  end

  defp render_coordination_slices(slices) do
    Markdown.heading(2, "Slices") <> "\n" <> Markdown.bullet_list(slice_items(slices, [])) <> "\n\n"
  end

  defp slice_items([], acc) do
    Enum.reverse(acc)
  end

  defp slice_items([slice | rest], acc) do
    status = Map.get(slice, :status, "unknown")
    text = "[" <> status <> "] " <> Map.get(slice, :id, "?") <> ": " <> Map.get(slice, :description, "")
    slice_items(rest, [text] ++ acc)
  end

  defp render_coordination_commits([]) do
    ""
  end

  defp render_coordination_commits(commits) do
    Markdown.heading(2, "Commits") <> "\n" <> Markdown.bullet_list(commit_items(commits, [])) <> "\n\n"
  end

  defp commit_items([], acc) do
    Enum.reverse(acc)
  end

  defp commit_items([commit | rest], acc) do
    text = Map.get(commit, :slice_id, "?") <> " → " <> Map.get(commit, :commit_hash, "?")
    commit_items(rest, [text] ++ acc)
  end

  defp render_coordination_archives([]) do
    ""
  end

  defp render_coordination_archives(archives) do
    Markdown.heading(2, "Archives") <> "\n" <> Markdown.bullet_list(archive_items(archives, [])) <> "\n\n"
  end

  defp archive_items([], acc) do
    Enum.reverse(acc)
  end

  defp archive_items([archive | rest], acc) do
    text = Map.get(archive, :source_file, "?") <> " → " <> Map.get(archive, :dest_file, "?") <> " (" <> Map.get(archive, :reason, "") <> ")"
    archive_items(rest, [text] ++ acc)
  end

  defp latest_run_id(path) do
    latest_loop_start_run(read_lines(path), "")
  end

  defp latest_loop_start_run([], current) do
    current
  end

  defp latest_loop_start_run([line | rest], current) do
    next =
    case extract_topic(line) do
      "loop.start" -> LoopUtils.nonempty_or(extract_run(line), current)
      _ -> current
    end

    latest_loop_start_run(rest, next)
  end

  defp next_run_id(path, config) do
    case LoopConfig.get(config, "core.run_id_format", "compact") do
      "counter" -> "run-" <> to_string(count_topic(read_lines(path), "loop.start", 0) + 1)
      _ -> LoopUtils.generate_compact_id("run")
    end
  end

  defp count_topic([], _topic, count) do
    count
  end

  defp count_topic([line | rest], topic, count) do
    case extract_topic(line) == topic do
      true -> count_topic(rest, topic, count + 1)
      _ -> count_topic(rest, topic, count)
    end
  end

  defp latest_iteration_for_run(path, run_id) do
    latest_iteration_from_lines(read_run_lines(path, run_id), "")
  end

  defp latest_iteration_from_lines([], current) do
    current
  end

  defp latest_iteration_from_lines([line | rest], current) do
    next =
    case extract_topic(line) do
      "iteration.start" -> LoopUtils.nonempty_or(extract_iteration(line), current)
      _ -> current
    end

    latest_iteration_from_lines(rest, next)
  end

  defp extract_run(line) do
    extract_field(line, "run")
  end

  defp extract_iteration(line) do
    extract_field(line, "iteration")
  end

  defp extract_field(line, key) do
    marker = "\"" <> key <> "\": "
    LoopJson.decode_json_value(first_quoted_value(first_after_marker(String.split(line, marker))))
  end

  defp first_after_marker([]) do
    ""
  end

  defp first_after_marker([_only]) do
    ""
  end

  defp first_after_marker([_prefix | rest]) do
    first_or_empty(rest)
  end

  defp extract_topic(line) do
    LoopJson.decode_json_value(first_quoted_value(first_after_marker(String.split(line, "\"topic\": "))))
  end

  defp first_quoted_value(text) do
    first_quoted_value_parts(String.split(text, "\""))
  end

  defp first_quoted_value_parts([]) do
    ""
  end

  defp first_quoted_value_parts([part | rest]) do
    case part do
      "" -> first_or_empty(rest)
      _ -> first_quoted_value_parts(rest)
    end
  end

  defp first_or_empty([]) do
    ""
  end

  defp first_or_empty([item | _rest]) do
    item
  end

  defp latest_agent_event([]) do
    ""
  end

  defp latest_agent_event(topics) do
    latest_agent_event_from_list(Enum.reverse(topics))
  end

  defp latest_agent_event_from_list([]) do
    ""
  end

  defp latest_agent_event_from_list([topic | rest]) do
    case system_topic(topic) do
      true -> latest_agent_event_from_list(rest)
      _ -> topic
    end
  end

  defp routing_event_from_lines([], current) do
    current
  end

  defp routing_event_from_lines([line | rest], current) do
    topic = extract_topic(line)

    case topic do
      "event.invalid" -> routing_event_from_lines(rest, invalid_recent_event(line, current))
      _ -> route_with_topic(rest, current, topic)
    end
  end

  defp route_with_topic(rest, current, topic) do
    case routing_topic(topic) do
      true -> routing_event_from_lines(rest, topic)
      _ -> routing_event_from_lines(rest, current)
    end
  end

  defp invalid_recent_event(line, current) do
    extracted = extract_field(line, "recent_event")

    case extracted do
      "" -> current
      value -> value
    end
  end

  defp routing_topic("iteration.start") do
    false
  end

  defp routing_topic("iteration.finish") do
    false
  end

  defp routing_topic("loop.complete") do
    false
  end

  defp routing_topic("loop.stop") do
    false
  end

  defp routing_topic("review.start") do
    false
  end

  defp routing_topic("review.finish") do
    false
  end

  defp routing_topic("backend.start") do
    false
  end

  defp routing_topic("backend.finish") do
    false
  end

  defp routing_topic("event.invalid") do
    false
  end

  defp routing_topic("") do
    false
  end

  defp routing_topic(topic) do
    not coordination_topic(topic)
  end

  defp system_topic(topic) do
    case coordination_topic(topic) do
      true -> true
      _ -> core_system_topic(topic)
    end
  end

  defp core_system_topic("iteration.start") do
    true
  end

  defp core_system_topic("iteration.finish") do
    true
  end

  defp core_system_topic("loop.start") do
    true
  end

  defp core_system_topic("loop.complete") do
    true
  end

  defp core_system_topic("loop.stop") do
    true
  end

  defp core_system_topic("review.start") do
    true
  end

  defp core_system_topic("review.finish") do
    true
  end

  defp core_system_topic("backend.start") do
    true
  end

  defp core_system_topic("backend.finish") do
    true
  end

  defp core_system_topic("event.invalid") do
    true
  end

  defp core_system_topic(topic) do
    String.starts_with(topic, "wave.")
  end

  defp coordination_topic("issue.discovered") do
    true
  end

  defp coordination_topic("issue.resolved") do
    true
  end

  defp coordination_topic("slice.started") do
    true
  end

  defp coordination_topic("slice.verified") do
    true
  end

  defp coordination_topic("slice.committed") do
    true
  end

  defp coordination_topic("context.archived") do
    true
  end

  defp coordination_topic("chain.spawn") do
    true
  end

  defp coordination_topic(_topic) do
    false
  end

  defp append_event(path, run_id, iteration, topic, fields_json) do
    append_text(path, event_line(run_id, iteration, topic, fields_json))
  end

  defp append_agent_event(path, run_id, iteration, topic, payload) do
    append_emitted_event(path, run_id, iteration, topic, payload, "agent")
  end

  defp append_harness_event(path, run_id, iteration, topic, payload) do
    append_emitted_event(path, run_id, iteration, topic, payload, "harness")
  end

  defp append_emitted_event(path, run_id, iteration, topic, payload, source) do
    append_text(path, emitted_event_line(run_id, iteration, topic, payload, source))
  end

  defp append_text(path, content) do
    System.run("printf '%s' " <> LoopUtils.shell_quote(content) <> " >> " <> LoopUtils.shell_quote(path))
  end

  defp event_line(run_id, iteration, topic, fields_json) do
    "{" <>
    record_prefix(run_id, iteration) <> LoopJson.json_field("topic", topic) <> ", " <> "\"fields\": {" <> fields_json <> "}}\n"
  end

  defp emitted_event_line(run_id, iteration, topic, payload, source) do
    "{" <>
    record_prefix(run_id, iteration) <> LoopJson.json_field("topic", topic) <> ", " <> LoopJson.json_field("payload", payload) <> ", " <> LoopJson.json_field("source", source) <> "}\n"
  end

  defp record_prefix(run_id, "") do
    LoopJson.json_field("run", run_id) <> ", "
  end

  defp record_prefix(run_id, iteration) do
    LoopJson.json_field("run", run_id) <> ", " <> LoopJson.json_field("iteration", iteration) <> ", "
  end


  defp read_if_exists(path) do
    case System.path_exists(path) do
      true -> System.read_text(path)
      _ -> ""
    end
  end

  defp print_summary(summary, loop) do
    stop_reason = Map.get(summary, :stop_reason, "unknown")

    print_lines(["miniloops summary", "===================","run_id: #{run_id(loop)}","iterations: #{Map.get(summary, :iterations, 0)}","stop_reason: #{stop_reason}","journal: #{journal_file(loop)}","memory: #{memory_file(loop)}","review_every: #{review_every(loop)}","inspect scratchpad: #{tool_path(loop)} inspect scratchpad --format md"])
  end

  defp print_text(text) do
    IO.puts(text)
  end

  defp print_projected_markdown(text, "terminal") do
    print_text(host_call(:io_render_markdown, text))
  end

  defp print_projected_markdown(text, _format) do
    print_text(text)
  end

  defp print_projected_text(text, "terminal") do
    print_text(host_call(:io_render_markdown, text))
  end

  defp print_projected_text(text, _format) do
    print_text(text)
  end

  defp print_lines([]) do
    :ok
  end

  defp print_lines([line | rest]) do
    case IO.puts(line) do
      _ -> print_lines(rest)
    end
  end

  defp print_iteration_banner(loop, iter) do
    iter_label = "iteration #{iteration(iter)}/#{max_iterations(loop)}"
    width = banner_width("━━━ " <> iter_label <> " ")
    rule = pad_right("━━━ " <> iter_label <> " ", "━", width)
    role_line = "role: " <> LoopUtils.list_text(allowed_roles(iter)) <> " │ event: " <> recent_event(iter) <> " │ next: " <> LoopUtils.list_text(allowed_events(iter))
    bottom_rule = String.duplicate("━", width)

    print_lines(["", rule, role_line, bottom_rule])
  end

  defp print_iteration_footer(iter, elapsed_s) do
    label = "──── end iteration #{iteration(iter)} (#{format_elapsed(elapsed_s)}) "
    print_lines([pad_right(label, "─", banner_width(label)), ""])
  end

  defp format_elapsed(seconds) do
    case seconds >= 60 do
      true -> to_string(div(seconds, 60)) <> "m " <> to_string(rem(seconds, 60)) <> "s"
      _ -> to_string(seconds) <> "s"
    end
  end

  defp epoch_seconds() do
    result = System.run("date +%s")
    String.to_integer(String.trim(Map.get(result, :output, "0")))
  end

  defp epoch_milliseconds() do
    result = System.run("python3 -c 'import time; print(int(time.time() * 1000))'")
    String.to_integer(String.trim(Map.get(result, :output, "0")))
  end

  defp print_review_banner(_loop, iteration) do
    label = "━━━ review before iteration #{iteration} "
    rule = pad_right(label, "━", banner_width(label))
    print_lines(["", rule])
  end

  defp banner_width(label) do
    terminal = terminal_width()
    label_width = String.length(label)

    case terminal > label_width do
      true -> terminal
      _ -> label_width
    end
  end

  defp terminal_width() do
    width = positive_env_int("MINILOOPS_WIDTH")

    case width > 0 do
      true -> width
      _ -> terminal_width_from_columns()
    end
  end

  defp terminal_width_from_columns() do
    width = positive_env_int("COLUMNS")

    case width > 0 do
      true -> width
      _ -> terminal_width_from_command()
    end
  end

  defp terminal_width_from_command() do
    width = command_positive_int("tput cols 2>/dev/null || true")

    case width > 0 do
      true -> width
      _ -> terminal_width_from_stty()
    end
  end

  defp terminal_width_from_stty() do
    width = command_positive_int("stty size 2>/dev/null | awk '{print $2}' || true")

    case width > 0 do
      true -> width
      _ -> 68
    end
  end

  defp positive_env_int(name) do
    case System.env(name) do
      nil -> 0
      "" -> 0
      value -> positive_int(value)
    end
  end

  defp command_positive_int(command) do
    result = System.run(command)
    positive_int(String.trim(Map.get(result, :output, "")))
  end

  defp positive_int(value) do
    parsed = parse_int_or_zero(value)

    case parsed > 0 do
      true -> parsed
      _ -> 0
    end
  end

  defp pad_right(text, char, width) do
    len = String.length(text)

    case len >= width do
      true -> text
      _ -> text <> String.duplicate(char, width - len)
    end
  end

  defp absolute_path(path) do
    case String.starts_with(path, "/") do
      true -> path
      _ -> Path.join(System.cwd(), path)
    end
  end

  defp objective(loop) do
    Map.get(loop, :objective, "")
  end

  defp topology(loop) do
    Map.get(loop, :topology, %{})
  end

  defp max_iterations(loop) do
    Map.get(Map.get(loop, :limits, %{}), :max_iterations, 0)
  end

  defp completion_promise(loop) do
    Map.get(Map.get(loop, :completion, %{}), :promise, "")
  end

  defp completion_event(loop) do
    Map.get(Map.get(loop, :completion, %{}), :event, "")
  end

  defp required_events(loop) do
    Map.get(Map.get(loop, :completion, %{}), :required_events, [])
  end

  defp backend_spec(loop) do
    Map.get(loop, :backend, %{})
  end

  defp backend_kind(loop) do
    Map.get(backend_spec(loop), :kind, "command")
  end

  defp backend_command(loop) do
    Map.get(backend_spec(loop), :command, "")
  end

  defp backend_args(loop) do
    Map.get(backend_spec(loop), :args, [])
  end

  defp backend_prompt_mode(loop) do
    Map.get(backend_spec(loop), :prompt_mode, "arg")
  end

  defp backend_timeout_ms(loop) do
    Map.get(backend_spec(loop), :timeout_ms, 300000)
  end

  defp review_spec(loop) do
    Map.get(loop, :review, %{})
  end

  defp review_enabled(loop) do
    case Map.get(review_spec(loop), :enabled, true) do
      false -> false
      _ -> true
    end
  end

  defp review_every(loop) do
    Map.get(review_spec(loop), :every, 1)
  end

  defp review_kind(loop) do
    Map.get(review_spec(loop), :kind, backend_kind(loop))
  end

  defp review_command(loop) do
    Map.get(review_spec(loop), :command, backend_command(loop))
  end

  defp review_args(loop) do
    Map.get(review_spec(loop), :args, backend_args(loop))
  end

  defp review_prompt_mode(loop) do
    Map.get(review_spec(loop), :prompt_mode, backend_prompt_mode(loop))
  end

  defp review_prompt(loop) do
    Map.get(review_spec(loop), :prompt, "")
  end

  defp review_timeout_ms(loop) do
    Map.get(review_spec(loop), :timeout_ms, backend_timeout_ms(loop))
  end

  defp process_kind(spec) do
    Map.get(spec, :kind, "command")
  end

  defp process_command(spec) do
    Map.get(spec, :command, "")
  end

  defp process_args(spec) do
    Map.get(spec, :args, [])
  end

  defp process_prompt_mode(spec) do
    Map.get(spec, :prompt_mode, "arg")
  end

  defp resolve_process_kind("pi", _command) do
    "pi"
  end

  defp resolve_process_kind("command", _command) do
    "command"
  end

  defp resolve_process_kind("passthrough", command) do
    resolve_process_kind("", command)
  end

  defp resolve_process_kind("", command) do
    case pi_binary(command) do
      true -> "pi"
      _ -> "command"
    end
  end

  defp resolve_process_kind(_value, command) do
    resolve_process_kind("", command)
  end

  defp pi_binary("pi") do
    true
  end

  defp pi_binary(command) do
    String.ends_with(command, "/pi")
  end

  defp normalize_prompt_mode("stdin") do
    "stdin"
  end

  defp normalize_prompt_mode(_value) do
    "arg"
  end

  defp config_list_with_fallback(config, key, fallback) do
    marker = "__missing__"
    raw = LoopConfig.get(config, key, marker)

    case raw == marker do
      true -> fallback
      _ -> LoopUtils.split_csv(raw)
    end
  end

  defp parallel_spec(loop) do
    Map.get(loop, :parallel, %{})
  end

  defp parallel_enabled(loop) do
    case Map.get(parallel_spec(loop), :enabled, false) do
      false -> false
      _ -> true
    end
  end

  defp parallel_max_branches(loop) do
    Map.get(parallel_spec(loop), :max_branches, 3)
  end

  defp parallel_branch_timeout_ms(loop) do
    Map.get(parallel_spec(loop), :branch_timeout_ms, 180000)
  end

  defp memory_budget_chars(loop) do
    Map.get(Map.get(loop, :memory, %{}), :budget_chars, 8000)
  end

  defp harness_instructions(loop) do
    Map.get(Map.get(loop, :harness, %{}), :instructions, "")
  end

  defp project_dir(loop) do
    Map.get(Map.get(loop, :paths, %{}), :project_dir, ".")
  end

  defp work_dir(loop) do
    Map.get(Map.get(loop, :paths, %{}), :work_dir, ".")
  end

  defp state_dir(loop) do
    Map.get(Map.get(loop, :paths, %{}), :state_dir, ".miniloop")
  end

  defp journal_file(loop) do
    Map.get(Map.get(loop, :paths, %{}), :journal_file, ".miniloop/journal.jsonl")
  end

  defp memory_file(loop) do
    Map.get(Map.get(loop, :paths, %{}), :memory_file, ".miniloop/memory.jsonl")
  end

  defp tool_path(loop) do
    Map.get(Map.get(loop, :paths, %{}), :tool_path, ".miniloop/miniloops")
  end

  defp pi_adapter_path(loop) do
    Map.get(Map.get(loop, :paths, %{}), :pi_adapter_path, ".miniloop/pi-adapter")
  end

  defp run_id(loop) do
    Map.get(Map.get(loop, :runtime, %{}), :run_id, "")
  end

  defp self_command(loop) do
    Map.get(Map.get(loop, :runtime, %{}), :self_command, "'miniloops'")
  end

  defp prompt_override(loop) do
    Map.get(Map.get(loop, :runtime, %{}), :prompt_override, nil)
  end

  defp backend_override(loop) do
    Map.get(Map.get(loop, :runtime, %{}), :backend_override, %{})
  end

  defp store(loop) do
    Map.get(loop, :store, %{})
  end

  defp log_level(loop) do
    Map.get(Map.get(loop, :runtime, %{}), :log_level, "info")
  end

  defp branch_mode(loop) do
    case Map.get(Map.get(loop, :runtime, %{}), :branch_mode, false) do
      false -> false
      _ -> true
    end
  end

  defp log(loop, level, message) do
    case log_level_rank(level) >= log_level_rank(log_level_atom(log_level(loop))) do
      true -> System.log(level, message, %{source: "miniloops"})
      _ -> :ok
    end
  end

  defp log_level_atom("debug") do
    :debug
  end

  defp log_level_atom("info") do
    :info
  end

  defp log_level_atom("warn") do
    :warn
  end

  defp log_level_atom("error") do
    :error
  end

  defp log_level_atom("none") do
    :none
  end

  defp log_level_atom(_other) do
    :info
  end

  defp log_level_rank(:debug) do
    0
  end

  defp log_level_rank(:info) do
    1
  end

  defp log_level_rank(:warn) do
    2
  end

  defp log_level_rank(:error) do
    3
  end

  defp log_level_rank(:none) do
    4
  end

  defp log_level_rank(_other) do
    1
  end

  defp resolve_log_level(nil, config_level) do
    config_level
  end

  defp resolve_log_level(cli_level, _config_level) do
    cli_level
  end

  defp log_level_name(loop) do
    log_level(loop)
  end

  defp print_failure_diagnostic(output) do
    tail = last_n_lines(output, 15)
    case tail do
      "" -> :ok
      _ -> print_lines(["", "── backend output (last 15 lines) ──", tail, "──────────────────────────────────────"])
    end
  end

  defp last_n_lines(text, n) do
    lines = String.split(text, LoopUtils.line_sep())
    total = list_length(lines, 0)
    drop_count = total - n
    case drop_count > 0 do
      true -> rejoin_lines(drop_n(lines, drop_count))
      _ -> text
    end
  end

  defp last_n_chars(text, n) do
    len = String.length(text)
    case len > n do
      true -> String.slice(text, len - n, n)
      _ -> text
    end
  end

  defp list_length([], acc) do
    acc
  end

  defp list_length([_head | rest], acc) do
    list_length(rest, acc + 1)
  end

  defp drop_n(list, 0) do
    list
  end

  defp drop_n([_head | rest], n) do
    drop_n(rest, n - 1)
  end

  defp take_n(_list, 0, acc) do
    Enum.reverse(acc)
  end

  defp take_n([], _n, acc) do
    Enum.reverse(acc)
  end

  defp take_n([head | rest], n, acc) do
    take_n(rest, n - 1, [head] ++ acc)
  end

  defp rejoin_lines([]) do
    ""
  end

  defp rejoin_lines([part]) do
    part
  end

  defp rejoin_lines([part | rest]) do
    part <> LoopUtils.line_sep() <> rejoin_lines(rest)
  end

  # --- Metrics collection and formatting ---

  defp collect_metrics_rows([], acc) do
    Enum.reverse(acc)
  end

  defp collect_metrics_rows([line | rest], acc) do
    topic = extract_topic(line)

    case topic do
      "iteration.start" -> collect_metrics_rows(rest, [metrics_row_from_start(line)] ++ acc)
      "iteration.finish" -> collect_metrics_rows(rest, merge_finish_into_rows(acc, line))
      _ -> collect_metrics_rows(rest, merge_event_into_rows(topic, line, acc))
    end
  end

  defp metrics_row_from_start(line) do
    roles = extract_field(line, "suggested_roles")
    role = first_csv_value(roles)

    %{iteration: extract_iteration(line), role: role, event: "none", elapsed_s: "", exit_code: "", timed_out: "false", outcome: "continue"}
  end

  defp first_csv_value("") do
    ""
  end

  defp first_csv_value(csv) do
    String.trim(first_or_empty(String.split(csv, ",")))
  end

  defp merge_finish_into_rows([], _line) do
    []
  end

  defp merge_finish_into_rows([current | rest], line) do
    iter = extract_iteration(line)

    case Map.get(current, :iteration, "") == iter do
      true -> [apply_finish_to_row(current, line)] ++ rest
      _ -> [current] ++ merge_finish_into_rows(rest, line)
    end
  end

  defp apply_finish_to_row(row, line) do
    exit_code = extract_field(line, "exit_code")
    timed_out = extract_field(line, "timed_out")
    elapsed_s = extract_field(line, "elapsed_s")
    outcome = compute_outcome(exit_code, timed_out, Map.get(row, :event, "none"))
    Map.put(Map.put(Map.put(Map.put(row, :exit_code, exit_code), :timed_out, timed_out), :elapsed_s, elapsed_s), :outcome, outcome)
  end

  defp merge_event_into_rows(_topic, _line, []) do
    []
  end

  defp merge_event_into_rows(topic, line, [current | rest]) do
    case system_topic(topic) do
      true -> [current] ++ rest
      _ -> try_merge_event(topic, line, current, rest)
    end
  end

  defp try_merge_event(topic, line, current, rest) do
    iter = extract_iteration(line)

    case Map.get(current, :iteration, "") == iter do
      true -> [Map.put(current, :event, topic)] ++ rest
      _ -> [current] ++ rest
    end
  end

  defp compute_outcome(exit_code, timed_out, event) do
    case timed_out do
      "true" -> "timeout"
      _ -> compute_outcome_from_exit(exit_code, event)
    end
  end

  defp compute_outcome_from_exit("0", event) do
    case event do
      "none" -> "continue"
      _ -> "emitted"
    end
  end

  defp compute_outcome_from_exit(_exit_code, _event) do
    "failed"
  end

  defp format_metrics(rows, "csv") do
    format_metrics_csv(rows)
  end

  defp format_metrics(rows, "json") do
    format_metrics_json(rows)
  end

  defp format_metrics(rows, "terminal") do
    format_metrics_md(rows)
  end

  defp format_metrics(rows, _format) do
    format_metrics_md(rows)
  end

  # --- Markdown table ---

  defp format_metrics_md([]) do
    "No metrics data available."
  end

  defp format_metrics_md(rows) do
    headers = ["iteration", "role", "event", "elapsed_s", "exit_code", "timed_out", "outcome"]
    table_rows = metrics_to_table_rows(rows, [])
    Markdown.table(headers, table_rows) <> "\n\n" <> metrics_summary(rows)
  end

  defp metrics_to_table_rows([], acc) do
    Enum.reverse(acc)
  end

  defp metrics_to_table_rows([row | rest], acc) do
    cells = [
      Map.get(row, :iteration, ""),
      Map.get(row, :role, ""),
      Map.get(row, :event, ""),
      Map.get(row, :elapsed_s, ""),
      Map.get(row, :exit_code, ""),
      Map.get(row, :timed_out, ""),
      Map.get(row, :outcome, "")
    ]
    metrics_to_table_rows(rest, [cells] ++ acc)
  end

  defp metrics_summary(rows) do
    total = to_string(list_length(rows, 0))
    elapsed = sum_elapsed_text(rows)
    events = count_distinct_events(rows, [])

    "**Summary:** " <> total <> " iterations, " <> elapsed <> "s total elapsed, " <> to_string(events) <> " distinct events"
  end

  defp sum_elapsed_text(rows) do
    vals = collect_elapsed_values(rows, [])

    case vals do
      [] -> "0"
      _ -> sum_elapsed_values(vals)
    end
  end

  defp collect_elapsed_values([], acc) do
    Enum.reverse(acc)
  end

  defp collect_elapsed_values([row | rest], acc) do
    case Map.get(row, :elapsed_s, "") do
      "" -> collect_elapsed_values(rest, acc)
      value -> collect_elapsed_values(rest, [value] ++ acc)
    end
  end

  defp sum_elapsed_values(values) do
    result = System.run("printf '%s' " <> LoopUtils.shell_quote(join_lines(values)) <> " | perl -ne 'chomp; next if $_ eq q{}; $sum += $_; END { printf \"%g\", $sum || 0 }'")
    String.trim(Map.get(result, :output, "0"))
  end

  defp join_lines([]) do
    ""
  end

  defp join_lines([item]) do
    item
  end

  defp join_lines([item | rest]) do
    item <> LoopUtils.line_sep() <> join_lines(rest)
  end

  defp parse_int_or_zero(s) do
    case Integer.parse(s) do
      {n, _} -> n
      _ -> 0
    end
  end

  defp count_distinct_events([], acc) do
    list_length(acc, 0)
  end

  defp count_distinct_events([row | rest], acc) do
    event = Map.get(row, :event, "none")

    case event do
      "none" -> count_distinct_events(rest, acc)
      _ -> count_distinct_events(rest, add_if_new(acc, event))
    end
  end

  defp add_if_new([], item) do
    [item]
  end

  defp add_if_new([head | rest], item) do
    case head == item do
      true -> [head] ++ rest
      _ -> [head] ++ add_if_new(rest, item)
    end
  end

  # --- CSV output (RFC 4180) ---

  defp format_metrics_csv([]) do
    "iteration,role,event,elapsed_s,exit_code,timed_out,outcome"
  end

  defp format_metrics_csv(rows) do
    "iteration,role,event,elapsed_s,exit_code,timed_out,outcome\n" <> metrics_csv_rows(rows)
  end

  defp metrics_csv_rows([]) do
    ""
  end

  defp metrics_csv_rows([row]) do
    metrics_csv_row(row)
  end

  defp metrics_csv_rows([row | rest]) do
    metrics_csv_row(row) <> "\n" <> metrics_csv_rows(rest)
  end

  defp metrics_csv_row(row) do
    csv_quote_field(Map.get(row, :iteration, "")) <> "," <> csv_quote_field(Map.get(row, :role, "")) <> "," <> csv_quote_field(Map.get(row, :event, "")) <> "," <> csv_quote_field(Map.get(row, :elapsed_s, "")) <> "," <> csv_quote_field(Map.get(row, :exit_code, "")) <> "," <> csv_quote_field(Map.get(row, :timed_out, "")) <> "," <> csv_quote_field(Map.get(row, :outcome, ""))
  end

  defp csv_quote_field(value) do
    case csv_needs_quoting(value) do
      true -> "\"" <> csv_escape_quotes(value) <> "\""
      _ -> value
    end
  end

  defp csv_needs_quoting(value) do
    String.contains(value, ",") or String.contains(value, "\"") or String.contains(value, "\n")
  end

  defp csv_escape_quotes(value) do
    case String.contains(value, "\"") do
      true -> join_with_escaped(String.split(value, "\""))
      _ -> value
    end
  end

  defp join_with_escaped([]) do
    ""
  end

  defp join_with_escaped([part]) do
    part
  end

  defp join_with_escaped([part | rest]) do
    part <> "\"\"" <> join_with_escaped(rest)
  end

  # --- JSON output ---

  defp format_metrics_json([]) do
    "[]"
  end

  defp format_metrics_json(rows) do
    "[" <> metrics_json_rows(rows) <> "]"
  end

  defp metrics_json_rows([]) do
    ""
  end

  defp metrics_json_rows([row]) do
    metrics_json_row(row)
  end

  defp metrics_json_rows([row | rest]) do
    metrics_json_row(row) <> ", " <> metrics_json_rows(rest)
  end

  defp metrics_json_row(row) do
    "{" <>
    json_number_field_or_null("iteration", Map.get(row, :iteration, "")) <> ", " <>
    json_str_field("role", Map.get(row, :role, "")) <> ", " <>
    json_str_field("event", Map.get(row, :event, "")) <> ", " <>
    json_number_field_or_null("elapsed_s", Map.get(row, :elapsed_s, "")) <> ", " <>
    json_number_field_or_null("exit_code", Map.get(row, :exit_code, "")) <> ", " <>
    json_bool_field("timed_out", Map.get(row, :timed_out, "")) <> ", " <>
    json_str_field("outcome", Map.get(row, :outcome, "")) <>
    "}"
  end

  defp json_str_field(key, value) do
    LoopJson.json_field(key, value)
  end

  defp json_number_field_or_null(key, "") do
    "\"" <> key <> "\": null"
  end

  defp json_number_field_or_null(key, value) do
    "\"" <> key <> "\": " <> value
  end

  defp json_bool_field(key, "true") do
    "\"" <> key <> "\": true"
  end

  defp json_bool_field(key, _value) do
    "\"" <> key <> "\": false"
  end

  defp json_escape_string(value) do
    case String.contains(value, "\"") do
      true -> join_with_json_escaped(String.split(value, "\""))
      _ -> value
    end
  end

  defp join_with_json_escaped([]) do
    ""
  end

  defp join_with_json_escaped([part]) do
    part
  end

  defp join_with_json_escaped([part | rest]) do
    part <> "\\\"" <> join_with_json_escaped(rest)
  end

  defp process_string_override(override, key, fallback) do
    case Map.get(override, key, nil) do
      nil -> fallback
      value -> value
    end
  end

  defp process_list_override(override, key, fallback) do
    case Map.get(override, key, nil) do
      nil -> fallback
      value -> value
    end
  end

  defp iteration(iter) do
    Map.get(iter, :iteration, 0)
  end

  defp iteration_string(iter) do
    to_string(iteration(iter))
  end

  defp recent_event(iter) do
    Map.get(iter, :recent_event, "loop.start")
  end

  defp allowed_roles(iter) do
    Map.get(iter, :allowed_roles, [])
  end

  defp allowed_events(iter) do
    Map.get(iter, :allowed_events, [])
  end

  defp backpressure(iter) do
    Map.get(iter, :backpressure, "")
  end

  defp prompt_text(iter) do
    Map.get(iter, :prompt, "")
  end
end
