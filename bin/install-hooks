#!/usr/bin/env bash
# Install project git hooks by symlinking hooks/* into .git/hooks/.
# Idempotent — safe to re-run at any time.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
HOOKS_SRC="$REPO_ROOT/hooks"
git_common_dir="$(git -C "$REPO_ROOT" rev-parse --git-common-dir 2>/dev/null)" || {
  echo "error: not a git repository ($REPO_ROOT)" >&2
  exit 1
}
case "$git_common_dir" in
  /*) git_dir="$git_common_dir" ;;
  *) git_dir="$REPO_ROOT/$git_common_dir" ;;
esac
GIT_HOOKS_DIR="$git_dir/hooks"

mkdir -p "$GIT_HOOKS_DIR"

installed=0
for hook in "$HOOKS_SRC"/*; do
  [ -f "$hook" ] || continue
  name="$(basename "$hook")"
  target="$GIT_HOOKS_DIR/$name"

  if [ -L "$target" ]; then
    existing="$(readlink "$target")"
    if [ "$existing" = "$hook" ]; then
      echo "  $name: already installed"
      installed=$((installed + 1))
      continue
    fi
    rm "$target"
  elif [ -e "$target" ]; then
    echo "  $name: backing up existing hook to $target.bak"
    mv "$target" "$target.bak"
  fi

  ln -s "$hook" "$target"
  echo "  $name: installed"
  installed=$((installed + 1))
done

if [ "$installed" -eq 0 ]; then
  echo "No hooks found in $HOOKS_SRC"
else
  echo "Done. $installed hook(s) installed."
fi
