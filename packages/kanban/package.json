{
  "name": "@mobrienv/autoloop-kanban",
  "version": "0.7.0",
  "description": "tmux-backed kanban board that spawns autoloop runs per task",
  "type": "module",
  "main": "dist/app.js",
  "types": "dist/app.d.ts",
  "exports": {
    ".": {
      "types": "./dist/app.d.ts",
      "default": "./dist/app.js"
    }
  },
  "files": [
    "dist",
    "src/kanban-tmux.conf"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@mobrienv/autoloop-core": "0.7.0",
    "hono": "^4.6.14"
  },
  "scripts": {
    "build": "tsc"
  },
  "publishConfig": {
    "access": "public"
  }
}
