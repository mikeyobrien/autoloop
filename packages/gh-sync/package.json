{
  "name": "@mobrienv/autoloop-gh-sync",
  "version": "0.9.2",
  "license": "MIT",
  "description": "GitHub issue sync adapter for autoloop (wraps gh CLI)",
  "type": "module",
  "main": "dist/index.js",
