  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.18.0",
    "@iarna/toml": "^2.2.5",
    "@mobrienv/autoloop-backends": "*",
    "@mobrienv/autoloop-core": "*"
  },
  "scripts": {
    "build": "tsc"
  },
  "publishConfig": {
    "access": "public"
  }
}
