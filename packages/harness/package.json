{
  "name": "@mobrienv/autoloop-harness",
  "version": "0.6.0",
  "description": "autoloop harness runtime (iteration loop, metareview, wave orchestration, backend drivers)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./emit": {
      "types": "./dist/emit.d.ts",
      "default": "./dist/emit.js"
    },
    "./events": {
      "types": "./dist/events.d.ts",
      "default": "./dist/events.js"
    },
    "./artifacts": {
      "types": "./dist/artifacts.d.ts",
      "default": "./dist/artifacts.js"
    },
    "./config-helpers": {
      "types": "./dist/config-helpers.d.ts",
      "default": "./dist/config-helpers.js"
    },
    "./coordination": {
      "types": "./dist/coordination.d.ts",
      "default": "./dist/coordination.js"
    },
    "./display": {
      "types": "./dist/display.d.ts",
      "default": "./dist/display.js"
    },
    "./metrics": {
      "types": "./dist/metrics.d.ts",
      "default": "./dist/metrics.js"
    },
    "./scratchpad": {
      "types": "./dist/scratchpad.d.ts",
      "default": "./dist/scratchpad.js"
    },
    "./metareview": {
      "types": "./dist/metareview.d.ts",
      "default": "./dist/metareview.js"
    },
    "./parallel": {
      "types": "./dist/parallel.d.ts",
      "default": "./dist/parallel.js"
    },
    "./iteration": {
      "types": "./dist/iteration.d.ts",
      "default": "./dist/iteration.js"
    },
    "./tools": {
      "types": "./dist/tools.d.ts",
      "default": "./dist/tools.js"
    },
    "./prompt": {
      "types": "./dist/prompt.d.ts",
      "default": "./dist/prompt.js"
    },
    "./wave/parse-objectives": {
      "types": "./dist/wave/parse-objectives.d.ts",
      "default": "./dist/wave/parse-objectives.js"
    },
    "./pi-adapter": {
      "types": "./dist/pi-adapter.d.ts",
      "default": "./dist/pi-adapter.js"
    },
    "./registry-bridge": {
      "types": "./dist/registry-bridge.d.ts",
      "default": "./dist/registry-bridge.js"
    }
