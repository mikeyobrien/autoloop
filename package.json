{
  "name": "@mobrienv/autoloop",
  "version": "0.5.0-sdk.0",
  "description": "Simpler, opinionated loop harness for inspectable long-running agent workflows",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cli": {
      "default": "./dist/main.js"
    }
  },
  "bin": {
    "autoloop": "bin/autoloop"
  },
  "files": [
    "bin/autoloop",
    "dist",
    "plugins/autoloop",
    "presets/autocode",
    "presets/autodebug",
    "presets/autodoc",
    "presets/autofix",
    "presets/autoideas",
    "presets/automerge",
    "presets/autoperf",
    "presets/autopr",
    "presets/autopreset",
    "presets/autoqa",
    "presets/autoresearch",
    "presets/autoreview",
    "presets/autosec",
    "presets/autosimplify",
    "presets/autospec",
    "presets/autotest",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikeyobrien/autoloop.git"
  },
  "homepage": "https://github.com/mikeyobrien/autoloop#readme",
  "bugs": {
    "url": "https://github.com/mikeyobrien/autoloop/issues"
  },
  "keywords": [
    "ai",
    "agents",
    "autonomous",
    "cli",
    "loops",
    "orchestration"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc",
    "lint": "biome check src/ test/",
    "lint:fix": "biome check --write src/ test/",
    "format": "biome format src/ test/",
    "format:fix": "biome format --write src/ test/",
    "test": "node --experimental-vm-modules node_modules/.bin/vitest run",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/vitest run --coverage",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/vitest",
    "check": "biome check src/ test/ && tsc --noEmit && npm run test:coverage",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepare": "husky",
    "version": "node -e \"const p=require('./plugins/autoloop/.claude-plugin/plugin.json');p.version=require('./package.json').version;require('fs').writeFileSync('./plugins/autoloop/.claude-plugin/plugin.json',JSON.stringify(p,null,2)+'\\n')\" && git add plugins/autoloop/.claude-plugin/plugin.json"
  },
  "lint-staged": {
    "*.{ts,js,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^3.2.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "playwright": "^1.59.1",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.4",
    "vitepress-plugin-llmstxt": "^0.5.1",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.18.0",
    "@hono/node-server": "^1.19.12",
    "@iarna/toml": "^2.2.5",
    "hono": "^4.12.10"
  }
}
