defmodule TopologyTest do
  def test_real_topology_loads_and_renders_with_context() do
    fixture_dir = prepare_fixture(topology_probe_main(repo_root()))
    result = run_fixture(fixture_dir)
    output = Map.get(result, :output, "")

    Assert.assert_equal(Map.get(result, :exit_code, 1), 0)
    Assert.assert_contains(output, "completion=task.complete")
    Assert.assert_contains(output, "render_has_topology=true")
    Assert.assert_contains(output, "render_has_role_deck=true")
    Assert.assert_contains(output, "with_context_has_builder=true")
    Assert.assert_contains(output, "with_context_has_review_ready=true")
  end

  def test_real_topology_reports_live_routing_sets() do
    fixture_dir = prepare_fixture(topology_routing_main(repo_root()))
    result = run_fixture(fixture_dir)
    output = Map.get(result, :output, "")

    Assert.assert_equal(Map.get(result, :exit_code, 1), 0)
    Assert.assert_contains(output, "role_count=")
    Assert.assert_contains(output, "suggested_roles=builder")
    Assert.assert_contains(output, "allowed_events=review.ready,build.blocked")
    Assert.assert_contains(output, "role_ids_has_builder=true")
    Assert.assert_contains(output, "handoff_keys_has_tasks_ready=true")
    Assert.assert_contains(output, "targets_has_builder=true")
    Assert.assert_contains(output, "emits_has_review_ready=true")
  end

  def test_real_topology_regex_matching_uses_source_implementation() do
    fixture_dir = prepare_fixture(topology_regex_main())
    result = run_fixture(fixture_dir)
    output = Map.get(result, :output, "")

    Assert.assert_equal(Map.get(result, :exit_code, 1), 0)
    Assert.assert_contains(output, "regex_review_passed=true")
    Assert.assert_contains(output, "regex_review_rejected=true")
    Assert.assert_contains(output, "regex_tasks_ready=false")
    Assert.assert_contains(output, "empty_patterns=false")
  end

  defp prepare_fixture(main_source) do
    dir = "/tmp/autoloops-topology-source-fixture"
    src_dir = Path.join(dir, "src")

    System.run("rm -rf " <> shell_quote(dir) <> " && mkdir -p " <> shell_quote(src_dir))
    System.write_text(Path.join(dir, "tonic.toml"), tonic_manifest())
    System.write_text(Path.join(src_dir, "main.tn"), main_source)
    link_source(dir, "topology.tn")
    link_source(dir, "utils.tn")

    dir
  end

  defp link_source(dir, file_name) do
    source = Path.join(repo_root(), "src/" <> file_name)
    target = Path.join(dir, "src/" <> file_name)
    System.run("ln -sf " <> shell_quote(source) <> " " <> shell_quote(target))
  end

  defp run_fixture(dir) do
    System.run("tonic run " <> shell_quote(dir))
  end

  defp topology_probe_main(project_dir) do
    "defmodule Demo do\n" <>
    "  def run() do\n" <>
    "    topology = LoopTopology.load(" <> tn_string(project_dir) <> ")\n" <>
    "    rendered = LoopTopology.render(topology, \"tasks.ready\")\n" <>
    "    with_context = LoopTopology.render_with_context(topology, \"tasks.ready\", [\"builder\"], [\"review.ready\"])\n" <>
    "    IO.puts(\"completion=\" <> LoopTopology.completion_event(topology, \"fallback.event\"))\n" <>
    "    IO.puts(\"render_has_topology=\" <> bool_text(String.contains(rendered, \"Topology\")))\n" <>
    "    IO.puts(\"render_has_role_deck=\" <> bool_text(String.contains(rendered, \"Role deck\")))\n" <>
    "    IO.puts(\"with_context_has_builder=\" <> bool_text(String.contains(with_context, \"Suggested next roles: builder\")))\n" <>
    "    IO.puts(\"with_context_has_review_ready=\" <> bool_text(String.contains(with_context, \"Allowed next events: review.ready\")))\n" <>
    "  end\n\n" <>
    "  defp bool_text(true) do\n" <>
    "    \"true\"\n" <>
    "  end\n\n" <>
    "  defp bool_text(_value) do\n" <>
    "    \"false\"\n" <>
    "  end\n" <>
    "end\n"
  end

  defp topology_routing_main(project_dir) do
    "defmodule Demo do\n" <>
    "  def run() do\n" <>
    "    topology = LoopTopology.load(" <> tn_string(project_dir) <> ")\n" <>
    "    suggested = LoopTopology.suggested_roles(topology, \"tasks.ready\")\n" <>
    "    allowed = LoopTopology.allowed_events(topology, \"tasks.ready\")\n" <>
    "    ids = LoopTopology.get_role_ids(topology)\n" <>
    "    keys = LoopTopology.handoff_keys(topology)\n" <>
    "    targets = LoopTopology.handoff_target_ids(topology)\n" <>
    "    emits = LoopTopology.all_emitted_events(topology)\n" <>
    "    IO.puts(\"role_count=\" <> to_string(LoopTopology.role_count(topology)))\n" <>
    "    IO.puts(\"suggested_roles=\" <> LoopUtils.join_csv(suggested))\n" <>
    "    IO.puts(\"allowed_events=\" <> LoopUtils.join_csv(allowed))\n" <>
    "    IO.puts(\"role_ids_has_builder=\" <> bool_text(LoopUtils.list_contains(ids, \"builder\")))\n" <>
    "    IO.puts(\"handoff_keys_has_tasks_ready=\" <> bool_text(LoopUtils.list_contains(keys, \"tasks.ready\")))\n" <>
    "    IO.puts(\"targets_has_builder=\" <> bool_text(LoopUtils.list_contains(targets, \"builder\")))\n" <>
    "    IO.puts(\"emits_has_review_ready=\" <> bool_text(LoopUtils.list_contains(emits, \"review.ready\")))\n" <>
    "  end\n\n" <>
    "  defp bool_text(true) do\n" <>
    "    \"true\"\n" <>
    "  end\n\n" <>
    "  defp bool_text(_value) do\n" <>
    "    \"false\"\n" <>
    "  end\n" <>
    "end\n"
  end

  defp topology_regex_main() do
    "defmodule Demo do\n" <>
    "  def run() do\n" <>
    "    patterns = [\"/review\\\\..+/\"]\n" <>
    "    IO.puts(\"regex_review_passed=\" <> bool_text(LoopTopology.event_matches_any(\"review.passed\", patterns)))\n" <>
    "    IO.puts(\"regex_review_rejected=\" <> bool_text(LoopTopology.event_matches_any(\"review.rejected\", patterns)))\n" <>
    "    IO.puts(\"regex_tasks_ready=\" <> bool_text(LoopTopology.event_matches_any(\"tasks.ready\", patterns)))\n" <>
    "    IO.puts(\"empty_patterns=\" <> bool_text(LoopTopology.event_matches_any(\"tasks.ready\", [])))\n" <>
    "  end\n\n" <>
    "  defp bool_text(true) do\n" <>
    "    \"true\"\n" <>
    "  end\n\n" <>
    "  defp bool_text(_value) do\n" <>
    "    \"false\"\n" <>
    "  end\n" <>
    "end\n"
  end

  defp tonic_manifest() do
    "[project]\nname = \"topology-source-test\"\nentry = \"src/main.tn\"\n"
  end

  defp repo_root() do
    System.cwd()
  end

  defp shell_quote(text) do
    "'" <> String.replace(text, "'", "'\\''") <> "'"
  end

  defp tn_string(text) do
    escaped = String.replace(String.replace(text, "\\", "\\\\"), "\"", "\\\"")
    "\"" <> escaped <> "\""
  end
end
