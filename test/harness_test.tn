# Tests for LoopHarness scratchpad rendering: prompt view compacts long histories,
# while inspect scratchpad keeps the richer full-history projection.

defmodule HarnessTest do
  def test_prompt_scratchpad_keeps_short_runs_full() do
    project_dir = prepare_fixture()
    prompt = inspect_prompt(project_dir, 4)

    Assert.refute(String.contains(prompt, "## Earlier iterations (compacted)"), "short runs should not use compact scratchpad header")
    Assert.assert_contains(prompt, "Loop-owned working files belong under:")
    Assert.assert_contains(prompt, "/.miniloop")
    Assert.assert_contains(prompt, "Do not leave loop-owned artifacts at the repo root.")
    Assert.assert_contains(prompt, "## Iteration 1")
    Assert.assert_contains(prompt, "detail line for iteration 1 with enough text to make the scratchpad visibly grow")
    Assert.assert_contains(prompt, "## Iteration 3")
  end

  def test_prompt_scratchpad_compacts_older_history_and_inspect_stays_full() do
    project_dir = prepare_fixture()
    prompt = inspect_prompt(project_dir, 6)
    scratchpad = inspect_scratchpad(project_dir)

    Assert.assert_contains(prompt, "## Earlier iterations (compacted)")
    Assert.assert_contains(prompt, "- Iteration 1 exit_code=0 — worker iteration 1")
    Assert.refute(String.contains(prompt, "detail line for iteration 1 with enough text to make the scratchpad visibly grow"), "old compacted iterations should not keep full detail in prompts")
    Assert.assert_contains(prompt, "## Iteration 5")
    Assert.assert_contains(prompt, "detail line for iteration 5 with enough text to make the scratchpad visibly grow")

    Assert.refute(String.contains(scratchpad, "## Earlier iterations (compacted)"), "inspect scratchpad should stay rich/full")
    Assert.assert_contains(scratchpad, "## Iteration 1")
    Assert.assert_contains(scratchpad, "detail line for iteration 1 with enough text to make the scratchpad visibly grow")
    Assert.assert_contains(scratchpad, "## Iteration 6")
  end

  def test_inspect_terminal_renders_markdown_without_changing_raw_md() do
    project_dir = prepare_fixture()
    raw = inspect_scratchpad(project_dir)
    pretty = inspect_scratchpad_terminal(project_dir)

    Assert.assert_contains(raw, "## Iteration 1")
    Assert.assert_contains(pretty, "Iteration 1")
    Assert.refute(String.contains(pretty, "## Iteration 1"), "terminal format should not dump raw markdown headings")
    Assert.assert_not_equal(pretty, raw)
  end

  def test_inspect_defaults_markdown_views_to_terminal() do
    project_dir = prepare_fixture()
    pretty = inspect_scratchpad_default(project_dir)

    Assert.assert_contains(pretty, "Iteration 1")
    Assert.refute(String.contains(pretty, "## Iteration 1"), "default inspect scratchpad should use terminal rendering")
  end

  def test_inspect_defaults_output_and_journal_to_raw_formats() do
    project_dir = prepare_fixture()
    output = inspect_output_default(project_dir, 1)
    journal = inspect_journal_default(project_dir)

    Assert.assert_contains(output, "worker iteration 1")
    Assert.assert_contains(output, "detail line for iteration 1")
    Assert.assert_contains(journal, "\"topic\": \"loop.start\"")
    Assert.assert_contains(journal, "\"topic\": \"iteration.finish\"")
  end

  def test_inspect_help_mentions_default_formats() do
    project_dir = prepare_fixture()
    help = inspect_help(project_dir)

    Assert.assert_contains(help, "[--format <md|terminal|text|json|csv>]")
    Assert.assert_contains(help, "scratchpad, prompt, memory, coordination, chain, metrics -> terminal")
    Assert.assert_contains(help, "output -> text")
    Assert.assert_contains(help, "journal -> json")
  end

  def test_inspect_rejects_missing_format_value() do
    project_dir = prepare_fixture()
    result = run_repo_command(project_dir, "inspect scratchpad --format")

    Assert.assert_contains(Map.get(result, :output, ""), "inspect requires a value after --format")
  end

  def test_parallel_metaprompt_renders_for_normal_parent_prompts() do
    project_dir = prepare_parallel_prompt_fixture()
    prompt = inspect_prompt(project_dir, 1)

    Assert.assert_contains(prompt, "Structured parallelism:")
    Assert.assert_contains(prompt, "`explore.parallel` is available")
    Assert.assert_contains(prompt, "`tasks.ready.parallel`")
    Assert.assert_contains(prompt, "1..2 distinct branch objectives")
    Assert.assert_contains(prompt, "only the harness may emit `*.parallel.joined`")
  end

  def test_metrics_json_emits_numbers_and_booleans_without_quotes() do
    project_dir = prepare_fixture()
    metrics = inspect_metrics_json(project_dir)

    Assert.assert_contains(metrics, "\"iteration\": 1")
    Assert.assert_contains(metrics, "\"elapsed_s\": ")
    Assert.assert_contains(metrics, "\"exit_code\": 0")
    Assert.assert_contains(metrics, "\"timed_out\": false")
    Assert.refute(String.contains(metrics, "\"iteration\": \"1\""), "iteration should be a JSON number")
    Assert.refute(String.contains(metrics, "\"exit_code\": \"0\""), "exit_code should be a JSON number")
    Assert.refute(String.contains(metrics, "\"timed_out\": \"false\""), "timed_out should be a JSON boolean")
  end

  def test_metrics_json_escapes_backslashes_and_control_chars() do
    project_dir = metrics_json_escape_fixture_dir()
    journal_dir = Path.join(project_dir, ".autoloops")
    journal_path = Path.join(journal_dir, "journal.jsonl")
    output_path = Path.join(project_dir, "out.json")

    System.run("rm -rf " <> shell_quote(project_dir) <> " && mkdir -p " <> shell_quote(journal_dir))
    System.write_text(journal_path, metrics_json_escape_journal())

    metrics = inspect_metrics_json_with_env(project_dir, journal_path, "run-1")
    System.write_text(output_path, metrics)

    parsed = System.run(
      "python3 -c " <>
      shell_quote(
        "import json, pathlib; " <>
        "doc = json.loads(pathlib.Path('" <> output_path <> "').read_text()); " <>
        "assert 'quoted' in doc[0]['role']; " <>
        "print('ok')"
      )
    )

    Assert.assert_equal(Map.get(parsed, :exit_code, 1), 0)
    Assert.assert_contains(metrics, "\\u000a")
    Assert.assert_contains(metrics, "\\u000d")
    Assert.assert_contains(metrics, "\\u0022quoted\\u0022")
    Assert.assert_contains(metrics, "\\u005c")
    Assert.assert_contains(Map.get(parsed, :output, ""), "ok")
  end

  def test_iteration_banners_expand_to_width_override() do
    project_dir = prepare_fixture()
    output = run_repo_command_with_env(project_dir, ".", "MINILOOPS_WIDTH=92")
    expected_rule = pad_banner("━━━ iteration 1/6 ", "━", 92)
    expected_bottom = String.duplicate("━", 92)

    Assert.assert_equal(Map.get(output, :exit_code, 1), 0)
    Assert.assert_contains(Map.get(output, :output, ""), expected_rule)
    Assert.assert_contains(Map.get(output, :output, ""), expected_bottom)
  end

  def test_metrics_md_summary_preserves_decimal_elapsed_precision() do
    project_dir = metrics_summary_fixture_dir()
    journal_dir = Path.join(project_dir, ".autoloops")
    journal_path = Path.join(journal_dir, "journal.jsonl")

    System.run("rm -rf " <> shell_quote(project_dir) <> " && mkdir -p " <> shell_quote(journal_dir))
    System.write_text(journal_path, metrics_summary_journal())

    metrics = inspect_metrics_md_with_env(project_dir, journal_path, "run-1")

    Assert.assert_contains(metrics, "| 1 | worker | none | 1.9 | 0 | false | continue |")
    Assert.assert_contains(metrics, "| 2 | worker | none | 2.4 | 0 | false | continue |")
    Assert.assert_contains(metrics, "**Summary:** 2 iterations, 4.3s total elapsed, 0 distinct events")
  end

  def test_named_chain_run_accepts_prompt_and_records_entry_objective() do
    project_dir = prepare_chain_prompt_fixture()
    prompt = "Ship the smallest viable change."
    result = run_repo_command(project_dir, "chain run prompt-chain . " <> shell_quote(prompt))
    chain_dir = Path.join(project_dir, ".miniloop/chains/chain-1")
    step1_handoff = System.read_text(Path.join(chain_dir, "step-1/handoff.md"))
    step2_handoff = System.read_text(Path.join(chain_dir, "step-2/handoff.md"))
    step1_prompt = System.read_text(Path.join(chain_dir, "step-1/.miniloop/prompt-seen.txt"))

    Assert.assert_equal(Map.get(result, :exit_code, 1), 0)
    Assert.assert_contains(step1_prompt, prompt)
    Assert.assert_contains(step1_handoff, "## Entry Objective")
    Assert.assert_contains(step1_handoff, prompt)
    Assert.assert_contains(step2_handoff, prompt)
    Assert.assert_contains(step2_handoff, "- Step 1 (first): completion_event")
  end

  def test_chain_advances_after_max_iterations_stop() do
    project_dir = prepare_chain_prompt_fixture_without_completion_event()
    result = run_repo_command(project_dir, "chain run prompt-chain .")
    chain_dir = Path.join(project_dir, ".miniloop/chains/chain-1")
    step2_prompt = System.read_text(Path.join(chain_dir, "step-2/.miniloop/prompt-seen.txt"))
    chain_state = run_repo_command(project_dir, "inspect chain --format md")

    Assert.assert_equal(Map.get(result, :exit_code, 1), 0)
    Assert.assert_equal(step2_prompt, "")
    Assert.assert_contains(Map.get(chain_state, :output, ""), "Step 1 (first) finished: max_iterations")
    Assert.assert_contains(Map.get(chain_state, :output, ""), "Step 2 (second) finished: max_iterations")
    Assert.assert_contains(Map.get(chain_state, :output, ""), "Outcome: all_steps_complete")
  end

  def test_inline_chain_defaults_to_bundle_root_and_uses_prompt_from_non_project_cwd() do
    harness_fixture = prepare_chain_prompt_fixture()
    cwd = "/tmp/autoloops-external-inline-chain-cwd"
    prompt = "Ship the smallest viable change."
    chain_csv = Path.join(harness_fixture, "presets/first") <> "," <> Path.join(harness_fixture, "presets/second")

    System.run("rm -rf " <> shell_quote(cwd) <> " && mkdir -p " <> shell_quote(cwd))

    result = run_harness_command(repo_root(), cwd, "run --chain " <> shell_quote(chain_csv) <> " " <> shell_quote(prompt))

    Assert.assert_equal(Map.get(result, :exit_code, 1), 0)
    Assert.assert_contains(Map.get(result, :output, ""), prompt)
  end

  def test_inline_chain_rejects_unknown_preset_names() do
    result = run_repo_command(repo_root(), "run --chain autoidea,autospec \"Ship the smallest viable change.\"")
    output = Map.get(result, :output, "")

    Assert.assert_contains(output, "error: invalid inline chain")
    Assert.assert_contains(output, "unknown preset: autoidea")
    Assert.refute(String.contains(output, "loop start run_id="), "invalid inline chain should not start a loop")
  end

  def test_run_rejects_unsupported_iterations_flag() do
    result = run_repo_command(repo_root(), "run -i 200 --chain autoideas,autospec \"Ship the smallest viable change.\"")
    output = Map.get(result, :output, "")

    Assert.assert_contains(output, "unsupported flag `-i`")
    Assert.refute(String.contains(output, "loop start run_id="), "unsupported flags should fail before loop startup")
  end

  def test_run_help_shows_run_usage_for_long_flag() do
    help = run_help(repo_root(), "--help")

    Assert.assert_contains(help, "Usage: autoloops run <preset-name|preset-dir> [prompt...] [flags]")
    Assert.assert_contains(help, "-h, --help")
    Assert.assert_contains(help, "Run 'autoloops list' to see all available presets.")
    Assert.refute(String.contains(help, "preset `--help` not found"), "run --help should not try to resolve --help as a preset")
    Assert.refute(String.contains(help, "loop start run_id="), "run --help should not start a loop")
  end

  def test_run_help_shows_run_usage_for_short_flag() do
    help = run_help(repo_root(), "-h")

    Assert.assert_contains(help, "Usage: autoloops run <preset-name|preset-dir> [prompt...] [flags]")
    Assert.assert_contains(help, "-h, --help")
    Assert.refute(String.contains(help, "preset `-h` not found"), "run -h should not try to resolve -h as a preset")
    Assert.refute(String.contains(help, "loop start run_id="), "run -h should not start a loop")
  end

  defp prepare_fixture() do
    project_dir = fixture_dir()
    backend_path = Path.join(project_dir, "backend.sh")
    roles_dir = Path.join(project_dir, "roles")

    System.run("rm -rf " <> shell_quote(project_dir) <> " && mkdir -p " <> shell_quote(roles_dir))

    System.write_text(backend_path, backend_script())
    System.run("chmod +x " <> shell_quote(backend_path))
    System.write_text(Path.join(project_dir, "autoloops.toml"), autoloops_toml(backend_path))
    System.write_text(Path.join(project_dir, "topology.toml"), topology_toml())
    System.write_text(Path.join(project_dir, "harness.md"), "scratchpad verification harness\n")
    System.write_text(Path.join(roles_dir, "worker.md"), "You are the worker. Emit the allowed event.\n")

    run_result = run_repo_command(project_dir, ".")
    Assert.assert_equal(Map.get(run_result, :exit_code, 1), 0)

    project_dir
  end

  defp prepare_parallel_prompt_fixture() do
    project_dir = parallel_prompt_fixture_dir()
    backend_path = Path.join(project_dir, "backend.sh")
    roles_dir = Path.join(project_dir, "roles")

    System.run("rm -rf " <> shell_quote(project_dir) <> " && mkdir -p " <> shell_quote(roles_dir))

    System.write_text(backend_path, parallel_prompt_backend_script())
    System.run("chmod +x " <> shell_quote(backend_path))
    System.write_text(Path.join(project_dir, "autoloops.toml"), parallel_prompt_autoloops_toml(backend_path))
    System.write_text(Path.join(project_dir, "topology.toml"), parallel_prompt_topology_toml())
    System.write_text(Path.join(project_dir, "harness.md"), "parallel prompt verification harness\n")
    System.write_text(Path.join(roles_dir, "planner.md"), "You are the planner.\n")

    run_result = run_repo_command(project_dir, ".")
    Assert.assert_equal(Map.get(run_result, :exit_code, 1), 0)

    project_dir
  end

  defp inspect_prompt(project_dir, iteration) do
    result = run_repo_command(project_dir, "inspect prompt " <> to_string(iteration) <> " --format md")
    Assert.assert_equal(Map.get(result, :exit_code, 1), 0)
    Map.get(result, :output, "")
  end

  defp inspect_scratchpad(project_dir) do
    result = run_repo_command(project_dir, "inspect scratchpad --format md")
    Assert.assert_equal(Map.get(result, :exit_code, 1), 0)
    Map.get(result, :output, "")
  end

  defp inspect_scratchpad_terminal(project_dir) do
    result = run_repo_command(project_dir, "inspect scratchpad --format terminal")
    Assert.assert_equal(Map.get(result, :exit_code, 1), 0)
    Map.get(result, :output, "")
  end

  defp inspect_scratchpad_default(project_dir) do
    result = run_repo_command(project_dir, "inspect scratchpad")
    Assert.assert_equal(Map.get(result, :exit_code, 1), 0)
    Map.get(result, :output, "")
  end

  defp inspect_output_default(project_dir, iteration) do
    result = run_repo_command(project_dir, "inspect output " <> to_string(iteration))
    Assert.assert_equal(Map.get(result, :exit_code, 1), 0)
    Map.get(result, :output, "")
  end

  defp inspect_journal_default(project_dir) do
    result = run_repo_command(project_dir, "inspect journal")
    Assert.assert_equal(Map.get(result, :exit_code, 1), 0)
    Map.get(result, :output, "")
  end

  defp inspect_help(project_dir) do
    result = run_repo_command(project_dir, "inspect --help")
    Assert.assert_equal(Map.get(result, :exit_code, 1), 0)
    Map.get(result, :output, "")
  end

  defp run_help(project_dir, flag) do
    result = run_repo_command(project_dir, "run " <> flag)
    Assert.assert_equal(Map.get(result, :exit_code, 1), 0)
    Map.get(result, :output, "")
  end

  defp inspect_metrics_json(project_dir) do
    result = run_repo_command(project_dir, "inspect metrics --format json")
    Assert.assert_equal(Map.get(result, :exit_code, 1), 0)
    Map.get(result, :output, "")
  end

  defp inspect_metrics_json_with_env(project_dir, journal_path, run_id) do
    result = System.run(
      "cd " <> shell_quote(project_dir) <>
      " && " <> clean_autoloops_env() <>
      " env MINILOOPS_JOURNAL_FILE=" <> shell_quote(journal_path) <>
      " MINILOOPS_RUN_ID=" <> shell_quote(run_id) <>
      " tonic run " <> shell_quote(repo_root()) <> " inspect metrics --format json"
    )

    Assert.assert_equal(Map.get(result, :exit_code, 1), 0)
    Map.get(result, :output, "")
  end

  defp inspect_metrics_md_with_env(project_dir, journal_path, run_id) do
    result = System.run(
      "cd " <> shell_quote(project_dir) <>
      " && " <> clean_autoloops_env() <>
      " env MINILOOPS_JOURNAL_FILE=" <> shell_quote(journal_path) <>
      " MINILOOPS_RUN_ID=" <> shell_quote(run_id) <>
      " tonic run " <> shell_quote(repo_root()) <> " inspect metrics --format md"
    )

    Assert.assert_equal(Map.get(result, :exit_code, 1), 0)
    Map.get(result, :output, "")
  end

  defp run_repo_command(project_dir, args) do
    run_repo_command_with_env(project_dir, args, "")
  end

  defp run_harness_command(harness_project, cwd, args) do
    System.run("cd " <> shell_quote(cwd) <> " && " <> clean_autoloops_env() <> " tonic run " <> shell_quote(harness_project) <> " " <> args)
  end

  defp run_repo_command_with_env(project_dir, args, extra_env) do
    extra = case extra_env do
      "" -> ""
      value -> value <> " "
    end

    System.run("cd " <> shell_quote(project_dir) <> " && " <> clean_autoloops_env() <> " " <> extra <> "tonic run " <> shell_quote(repo_root()) <> " " <> args)
  end

  defp clean_autoloops_env() do
    "env" <>
    " -u COLUMNS" <>
    " -u MINILOOPS_ALLOWED_EVENTS" <>
    " -u MINILOOPS_ALLOWED_ROLES" <>
    " -u MINILOOPS_BIN" <>
    " -u MINILOOPS_COMPLETION_EVENT" <>
    " -u MINILOOPS_COMPLETION_PROMISE" <>
    " -u MINILOOPS_EVENTS_FILE" <>
    " -u MINILOOPS_ITERATION" <>
    " -u MINILOOPS_JOURNAL_FILE" <>
    " -u MINILOOPS_MEMORY_FILE" <>
    " -u MINILOOPS_PROJECT_DIR" <>
    " -u MINILOOPS_PROMPT" <>
    " -u MINILOOPS_RECENT_EVENT" <>
    " -u MINILOOPS_REQUIRED_EVENTS" <>
    " -u MINILOOPS_RUN_ID" <>
    " -u MINILOOPS_STATE_DIR" <>
    " -u MINILOOPS_WIDTH"
  end

  defp backend_script() do
    "#!/bin/sh\n" <>
    "set -eu\n" <>
    "first_event=$(printf '%s' \"${MINILOOPS_ALLOWED_EVENTS:-}\" | awk -F, '{print $1}')\n" <>
    "printf 'worker iteration %s\\n' \"${MINILOOPS_ITERATION:-?}\"\n" <>
    "printf 'detail line for iteration %s with enough text to make the scratchpad visibly grow\\n' \"${MINILOOPS_ITERATION:-?}\"\n" <>
    "printf 'another detail line for iteration %s\\n' \"${MINILOOPS_ITERATION:-?}\"\n" <>
    "if [ -n \"$first_event\" ] && [ -n \"${MINILOOPS_BIN:-}\" ]; then\n" <>
    "  \"$MINILOOPS_BIN\" emit \"$first_event\" \"handoff from iteration ${MINILOOPS_ITERATION:-?}\"\n" <>
    "fi\n"
  end

  defp parallel_prompt_backend_script() do
    "#!/bin/sh\n" <>
    "set -eu\n" <>
    "printf 'LOOP_COMPLETE\\n'\n"
  end

  defp autoloops_toml(backend_path) do
    "event_loop.max_iterations = 6\n" <>
    "event_loop.completion_event = \"task.complete\"\n" <>
    "backend.kind = \"command\"\n" <>
    "backend.command = \"" <> backend_path <> "\"\n" <>
    "backend.timeout_ms = 10000\n" <>
    "review.enabled = false\n" <>
    "memory.prompt_budget_chars = 1600\n" <>
    "harness.instructions_file = \"harness.md\"\n" <>
    "core.state_dir = \".miniloop\"\n" <>
    "core.journal_file = \".miniloop/journal.jsonl\"\n" <>
    "core.memory_file = \".miniloop/memory.jsonl\"\n"
  end

  defp parallel_prompt_autoloops_toml(backend_path) do
    "event_loop.max_iterations = 1\n" <>
    "event_loop.completion_event = \"task.complete\"\n" <>
    "backend.kind = \"command\"\n" <>
    "backend.command = \"" <> backend_path <> "\"\n" <>
    "backend.timeout_ms = 10000\n" <>
    "review.enabled = false\n" <>
    "parallel.enabled = true\n" <>
    "parallel.max_branches = 2\n" <>
    "parallel.branch_timeout_ms = 5000\n" <>
    "memory.prompt_budget_chars = 1600\n" <>
    "harness.instructions_file = \"harness.md\"\n" <>
    "core.state_dir = \".miniloop\"\n" <>
    "core.journal_file = \".miniloop/journal.jsonl\"\n" <>
    "core.memory_file = \".miniloop/memory.jsonl\"\n"
  end

  defp topology_toml() do
    "name = \"compact-check\"\n" <>
    "completion = \"task.complete\"\n\n" <>
    "[[role]]\n" <>
    "id = \"worker\"\n" <>
    "emits = [\"loop.next\"]\n" <>
    "prompt_file = \"roles/worker.md\"\n\n" <>
    "[handoff]\n" <>
    "\"loop.start\" = [\"worker\"]\n" <>
    "\"loop.next\" = [\"worker\"]\n"
  end

  defp parallel_prompt_topology_toml() do
    "name = \"parallel-prompt-check\"\n" <>
    "completion = \"task.complete\"\n\n" <>
    "[[role]]\n" <>
    "id = \"planner\"\n" <>
    "emits = [\"tasks.ready\"]\n" <>
    "prompt_file = \"roles/planner.md\"\n\n" <>
    "[handoff]\n" <>
    "\"loop.start\" = [\"planner\"]\n"
  end

  defp chain_prompt_backend_script() do
    "#!/bin/sh\n" <>
    "set -eu\n" <>
    "mkdir -p \"${MINILOOPS_STATE_DIR:-.}\"\n" <>
    "printf '%s' \"${1:-}\" > \"${MINILOOPS_STATE_DIR:-.}/prompt-seen.txt\"\n" <>
    "printf '%s\\n' \"${1:-}\"\n" <>
    "first_event=$(printf '%s' \"${MINILOOPS_ALLOWED_EVENTS:-}\" | awk -F, '{print $1}')\n" <>
    "if [ -n \"$first_event\" ] && [ -n \"${MINILOOPS_BIN:-}\" ]; then\n" <>
    "  \"$MINILOOPS_BIN\" emit \"$first_event\" \"chain prompt ok\"\n" <>
    "fi\n"
  end

  defp chain_prompt_backend_script_without_completion_event() do
    "#!/bin/sh\n" <>
    "set -eu\n" <>
    "mkdir -p \"${MINILOOPS_STATE_DIR:-.}\"\n" <>
    "printf '%s' \"${1:-}\" > \"${MINILOOPS_STATE_DIR:-.}/prompt-seen.txt\"\n" <>
    "printf 'no completion event emitted\\n'\n"
  end

  defp chain_host_autoloops_toml() do
    "core.state_dir = \".miniloop\"\n" <>
    "core.journal_file = \".miniloop/journal.jsonl\"\n" <>
    "core.memory_file = \".miniloop/memory.jsonl\"\n" <>
    "core.run_id_format = \"counter\"\n"
  end

  defp chain_prompt_preset_autoloops_toml(backend_path) do
    "event_loop.max_iterations = 1\n" <>
    "event_loop.completion_event = \"task.complete\"\n" <>
    "backend.kind = \"command\"\n" <>
    "backend.command = \"" <> backend_path <> "\"\n" <>
    "backend.timeout_ms = 10000\n" <>
    "review.enabled = false\n" <>
    "harness.instructions_file = \"harness.md\"\n" <>
    "core.state_dir = \".miniloop\"\n" <>
    "core.journal_file = \".miniloop/journal.jsonl\"\n" <>
    "core.memory_file = \".miniloop/memory.jsonl\"\n"
  end

  defp chain_prompt_topology_toml() do
    "name = \"chain-prompt-check\"\n" <>
    "completion = \"task.complete\"\n\n" <>
    "[[role]]\n" <>
    "id = \"worker\"\n" <>
    "emits = [\"task.complete\"]\n" <>
    "prompt_file = \"roles/worker.md\"\n\n" <>
    "[handoff]\n" <>
    "\"loop.start\" = [\"worker\"]\n"
  end

  defp prepare_chain_prompt_fixture() do
    prepare_chain_prompt_fixture_with_backend(chain_prompt_fixture_dir(), chain_prompt_backend_script())
  end

  defp prepare_chain_prompt_fixture_without_completion_event() do
    prepare_chain_prompt_fixture_with_backend("/tmp/autoloops-chain-prompt-no-complete-fixture", chain_prompt_backend_script_without_completion_event())
  end

  defp prepare_chain_prompt_fixture_with_backend(project_dir, backend_script) do
    backend_path = Path.join(project_dir, "backend.sh")
    first_dir = Path.join(project_dir, "presets/first")
    second_dir = Path.join(project_dir, "presets/second")

    System.run("rm -rf " <> shell_quote(project_dir) <> " && mkdir -p " <> shell_quote(Path.join(first_dir, "roles")) <> " " <> shell_quote(Path.join(second_dir, "roles")))

    System.write_text(backend_path, backend_script)
    System.run("chmod +x " <> shell_quote(backend_path))
    System.write_text(Path.join(project_dir, "autoloops.toml"), chain_host_autoloops_toml())
    System.write_text(Path.join(project_dir, "chains.toml"), "[[chain]]\nname = \"prompt-chain\"\nsteps = [\"first\", \"second\"]\n")
    write_chain_prompt_preset(first_dir, backend_path)
    write_chain_prompt_preset(second_dir, backend_path)

    project_dir
  end

  defp write_chain_prompt_preset(preset_dir, backend_path) do
    System.write_text(Path.join(preset_dir, "autoloops.toml"), chain_prompt_preset_autoloops_toml(backend_path))
    System.write_text(Path.join(preset_dir, "topology.toml"), chain_prompt_topology_toml())
    System.write_text(Path.join(preset_dir, "harness.md"), "chain prompt harness\n")
    System.write_text(Path.join(preset_dir, "roles/worker.md"), "You are the worker. Emit task.complete.\n")
  end

  defp fixture_dir() do
    "/tmp/autoloops-scratchpad-fixture"
  end

  defp chain_prompt_fixture_dir() do
    "/tmp/autoloops-chain-prompt-fixture"
  end

  defp parallel_prompt_fixture_dir() do
    "/tmp/autoloops-parallel-prompt-fixture"
  end

  defp metrics_summary_fixture_dir() do
    "/tmp/autoloops-metrics-summary-fixture"
  end

  defp metrics_json_escape_fixture_dir() do
    "/tmp/autoloops-json-escape-fixture"
  end

  defp metrics_summary_journal() do
    "{\"run\": \"run-1\", \"topic\": \"loop.start\", \"fields\": {}}\n" <>
    "{\"run\": \"run-1\", \"iteration\": \"1\", \"topic\": \"iteration.start\", \"fields\": {\"suggested_roles\": \"worker\"}}\n" <>
    "{\"run\": \"run-1\", \"iteration\": \"1\", \"topic\": \"iteration.finish\", \"fields\": {\"exit_code\": \"0\", \"timed_out\": false, \"elapsed_s\": \"1.9\", \"output\": \"\"}}\n" <>
    "{\"run\": \"run-1\", \"iteration\": \"2\", \"topic\": \"iteration.start\", \"fields\": {\"suggested_roles\": \"worker\"}}\n" <>
    "{\"run\": \"run-1\", \"iteration\": \"2\", \"topic\": \"iteration.finish\", \"fields\": {\"exit_code\": \"0\", \"timed_out\": false, \"elapsed_s\": \"2.4\", \"output\": \"\"}}\n"
  end

  defp metrics_json_escape_journal() do
    "{\"run\": \"run-1\", \"topic\": \"loop.start\", \"fields\": {}}\n" <>
    "{\"run\": \"run-1\", \"iteration\": \"1\", \"topic\": \"iteration.start\", \"fields\": {\"suggested_roles\": \"path \\\\temp\\u000aline2\\u000dline3 \\u0022quoted\\u0022\"}}\n" <>
    "{\"run\": \"run-1\", \"iteration\": \"1\", \"topic\": \"iteration.finish\", \"fields\": {\"exit_code\": \"0\", \"timed_out\": false, \"elapsed_s\": \"1.2\", \"output\": \"\"}}\n"
  end

  defp repo_root() do
    System.cwd()
  end

  defp pad_banner(text, char, width) do
    len = String.length(text)

    case len >= width do
      true -> text
      _ -> text <> String.duplicate(char, width - len)
    end
  end

  defp shell_quote(text) do
    "'" <> String.replace(text, "'", "'\\''") <> "'"
  end
end
