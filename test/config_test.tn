defmodule ConfigTest do
  def test_real_config_defaults_and_project_load() do
    fixture_dir = prepare_fixture(config_probe_main(repo_root()))
    result = run_fixture(fixture_dir)
    output = Map.get(result, :output, "")

    Assert.assert_equal(Map.get(result, :exit_code, 1), 0)
    Assert.assert_contains(output, "default_backend=pi")
    Assert.assert_contains(output, "default_run_id_format=compact")
    Assert.assert_contains(output, "default_log_level=info")
    Assert.assert_contains(output, "loaded_backend_kind=pi")
    Assert.assert_contains(output, "loaded_state_dir=.autoloop")
    Assert.assert_contains(output, "loaded_memory_file=.autoloop/memory.jsonl")
    Assert.assert_contains(output, "loaded_journal_in=/tmp/config-work/.autoloop/journal.jsonl")
    Assert.assert_contains(output, "loaded_memory_in=/tmp/config-work/.autoloop/memory.jsonl")
    Assert.assert_contains(output, "loaded_state_dir_name=.autoloop")
    Assert.assert_contains(output, "loaded_state_dir_path=" <> repo_root() <> "/.autoloop")
  end

  def test_real_config_resolves_bundled_presets() do
    fixture_dir = prepare_fixture(config_resolve_probe_main(repo_root()))
    result = run_fixture(fixture_dir)
    output = Map.get(result, :output, "")

    Assert.assert_equal(Map.get(result, :exit_code, 1), 0)
    Assert.assert_contains(output, "autosimplify=" <> repo_root() <> "/presets/autosimplify")
    Assert.assert_contains(output, "autocode=" <> repo_root() <> "/presets/autocode")
    Assert.assert_contains(output, "unknown_is_empty=true")
  end

  def test_real_config_reads_project_required_events() do
    fixture_dir = prepare_fixture(config_required_events_probe_main(repo_root()))
    result = run_fixture(fixture_dir)
    output = Map.get(result, :output, "")

    Assert.assert_equal(Map.get(result, :exit_code, 1), 0)
    Assert.assert_contains(output, "required_events=review.passed")
    Assert.assert_contains(output, "project_has_config=true")
  end

  defp prepare_fixture(main_source) do
    dir = "/tmp/autoloops-config-source-fixture"
    src_dir = Path.join(dir, "src")

    System.run("rm -rf " <> shell_quote(dir) <> " && mkdir -p " <> shell_quote(src_dir))
    System.write_text(Path.join(dir, "tonic.toml"), tonic_manifest())
    System.write_text(Path.join(src_dir, "main.tn"), main_source)
    link_source(dir, "config.tn")
    link_source(dir, "utils.tn")

    dir
  end

  defp link_source(dir, file_name) do
    source = Path.join(repo_root(), "src/" <> file_name)
    target = Path.join(dir, "src/" <> file_name)
    System.run("ln -sf " <> shell_quote(source) <> " " <> shell_quote(target))
  end

  defp run_fixture(dir) do
    System.run("tonic run " <> shell_quote(dir))
  end

  defp config_probe_main(project_dir) do
    "defmodule Demo do\n" <>
    "  def run() do\n" <>
    "    default = LoopConfig.load(\"/definitely/missing/config.toml\")\n" <>
    "    loaded = LoopConfig.load_project(" <> tn_string(project_dir) <> ")\n" <>
    "    IO.puts(\"default_backend=\" <> LoopConfig.get(default, \"backend.command\", \"\"))\n" <>
    "    IO.puts(\"default_run_id_format=\" <> LoopConfig.get(default, \"core.run_id_format\", \"\"))\n" <>
    "    IO.puts(\"default_log_level=\" <> LoopConfig.get(default, \"core.log_level\", \"\"))\n" <>
    "    IO.puts(\"loaded_backend_kind=\" <> LoopConfig.get(loaded, \"backend.kind\", \"\"))\n" <>
    "    IO.puts(\"loaded_state_dir=\" <> LoopConfig.get(loaded, \"core.state_dir\", \"\"))\n" <>
    "    IO.puts(\"loaded_memory_file=\" <> LoopConfig.get(loaded, \"core.memory_file\", \"\"))\n" <>
    "    IO.puts(\"loaded_journal_in=\" <> LoopConfig.resolve_journal_file_in(" <> tn_string(project_dir) <> ", \"/tmp/config-work\"))\n" <>
    "    IO.puts(\"loaded_memory_in=\" <> LoopConfig.resolve_memory_file_in(" <> tn_string(project_dir) <> ", \"/tmp/config-work\"))\n" <>
    "    IO.puts(\"loaded_state_dir_name=\" <> LoopConfig.state_dir_name(" <> tn_string(project_dir) <> "))\n" <>
    "    IO.puts(\"loaded_state_dir_path=\" <> LoopConfig.state_dir_path(" <> tn_string(project_dir) <> "))\n" <>
    "  end\n" <>
    "end\n"
  end

  defp config_resolve_probe_main(project_dir) do
    "defmodule Demo do\n" <>
    "  def run() do\n" <>
    "    IO.puts(\"autosimplify=\" <> LoopConfig.resolve_project_dir(\"autosimplify\", " <> tn_string(project_dir) <> "))\n" <>
    "    IO.puts(\"autocode=\" <> LoopConfig.resolve_project_dir(\"autocode\", " <> tn_string(project_dir) <> "))\n" <>
    "    IO.puts(\"unknown_is_empty=\" <> bool_text(LoopConfig.resolve_project_dir(\"definitely-not-a-preset\", " <> tn_string(project_dir) <> ") == \"\"))\n" <>
    "  end\n\n" <>
    "  defp bool_text(true) do\n" <>
    "    \"true\"\n" <>
    "  end\n\n" <>
    "  defp bool_text(_value) do\n" <>
    "    \"false\"\n" <>
    "  end\n" <>
    "end\n"
  end

  defp config_required_events_probe_main(project_dir) do
    "defmodule Demo do\n" <>
    "  def run() do\n" <>
    "    config = LoopConfig.load_project(" <> tn_string(project_dir) <> ")\n" <>
    "    IO.puts(\"required_events=\" <> LoopUtils.join_csv(LoopConfig.get_list(config, \"event_loop.required_events\")))\n" <>
    "    IO.puts(\"project_has_config=\" <> bool_text(LoopConfig.project_has_config(" <> tn_string(project_dir) <> ")))\n" <>
    "  end\n\n" <>
    "  defp bool_text(true) do\n" <>
    "    \"true\"\n" <>
    "  end\n\n" <>
    "  defp bool_text(_value) do\n" <>
    "    \"false\"\n" <>
    "  end\n" <>
    "end\n"
  end

  defp tonic_manifest() do
    "[project]\nname = \"config-source-test\"\nentry = \"src/main.tn\"\n"
  end

  defp repo_root() do
    System.cwd()
  end

  defp shell_quote(text) do
    "'" <> String.replace(text, "'", "'\\''") <> "'"
  end

  defp tn_string(text) do
    escaped = String.replace(String.replace(text, "\\", "\\\\"), "\"", "\\\"")
    "\"" <> escaped <> "\""
  end
end
